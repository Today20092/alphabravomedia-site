---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntries, render } from "astro:content";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Gallery from "../../components/Gallery.astro";
import ServicePreviewCard from "../../components/ServicePreviewCard.astro";
import { siteConfig } from "../../site-config";

export async function getStaticPaths() {
  const items = await getCollection("portfolio");
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const gearUsedRaw = item.data.gearUsed ? await getEntries(item.data.gearUsed) : [];
const gearUsed = gearUsedRaw.filter((gear) => gear !== undefined);
if (gearUsedRaw.some((g) => g === undefined)) {
  console.warn(
    `Some gear items could not be resolved in ${item.data.title}. Provided IDs:`,
    item.data.gearUsed,
  );
}

const allItems = await getCollection("portfolio");
const allServices = await getCollection("services");
const relatedItems = allItems
  .filter((i) => i.id !== item.id && i.data.category === item.data.category)
  .slice(0, 2);
const relatedServices = allServices.filter((service) =>
  item.data.services.includes(service.id),
);
const portfolioDescription = item.data.clientName
  ? `${item.data.clientName} ${item.data.category.toLowerCase()} project by Alpha Bravo Media, covering production approach, outcomes, and deliverables.`
  : `${item.data.category} project by Alpha Bravo Media, covering production approach, outcomes, and deliverables.`;
const portfolioOgImage = item.data.image?.src ??
  (item.data.videoId
    ? `https://img.youtube.com/vi/${item.data.videoId}/maxresdefault.jpg`
    : "/alpha-bravo-logo.svg");
---

<BaseLayout
  title={`${item.data.title} | Work Example | Alpha Bravo Media`}
  description={portfolioDescription}
  ogImage={portfolioOgImage}
  ogImageAlt={item.data.title}
  ogType="article"
  author={siteConfig.founderName}
>
  <article
    data-pagefind-body
    class="site-section-hero"
    itemscope
    itemtype="https://schema.org/CreativeWork"
  >
    <span data-pagefind-meta="type" class="sr-only">Work</span>
    <span data-pagefind-meta="client" style="display:none">{item.data.clientName}</span>

    <div class="site-shell">
      <a href={`${base}portfolio`} class="site-link inline-flex items-center gap-2 text-sm">
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        Back to Work
      </a>

      <header class="site-page-header mt-8">
        <span class="site-chip">{item.data.category}</span>
        <h1 itemprop="headline" class="site-page-title max-w-4xl">{item.data.title}</h1>
        <div class="site-meta-row">
          <span>Client</span>
          <span class="text-site-text">{item.data.clientName}</span>
          <a href={`${base}about`} rel="author" itemprop="author" class="site-link">
            Produced by {siteConfig.founderName}
          </a>
        </div>
      </header>

      {(item.data.videoId || item.data.facebookUrl || item.data.image) && (
        <div class="site-card mb-12 overflow-hidden">
          <div class="site-card-media aspect-video">
            {item.data.videoId ? (
              <YouTube
                id={item.data.videoId}
                posterQuality="max"
                class="m-0 w-full max-w-full aspect-video"
              />
            ) : item.data.facebookUrl ? (
              <iframe
                src={`https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(item.data.facebookUrl)}&show_text=0&t=0`}
                class="w-full aspect-video border-none overflow-hidden"
                scrolling="no"
                frameborder="0"
                allowfullscreen="true"
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
              />
            ) : item.data.image ? (
              <Image
                src={item.data.image}
                alt={item.data.title}
                class="h-full w-full object-cover"
              />
            ) : null}
          </div>
        </div>
      )}

      <div
        class="site-prose prose prose-a:text-site-accent-strong md:prose-lg max-w-none mb-16 prose-headings:text-balance prose-h1:text-3xl md:prose-h1:text-4xl prose-h2:text-2xl md:prose-h2:text-3xl prose-h3:text-xl md:prose-h3:text-2xl"
      >
        <Content />
      </div>

      {(item.data.proofPoints.length > 0 || item.data.channelUrl || item.data.playlistUrl) && (
        <section class="site-panel mb-16 p-6 sm:p-8">
          <div class="grid gap-8 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
            <div>
              <span class="site-kicker">Production volume</span>
              <h2 class="site-section-title mt-4">Built as an ongoing content system.</h2>
              <p class="site-section-copy mt-4">
                This case study represents repeatable production work across published
                episodes, not a one-off portfolio sample.
              </p>
              <div class="mt-6 flex flex-wrap gap-3">
                {item.data.channelUrl && (
                  <a
                    href={item.data.channelUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="site-button-primary"
                  >
                    <Icon name="simple-icons:youtube" class="h-4 w-4" />
                    View channel
                  </a>
                )}
                {item.data.playlistUrl && (
                  <a
                    href={item.data.playlistUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="site-button-secondary"
                  >
                    <Icon name="mdi:playlist-play" class="h-5 w-5" />
                    View playlist
                  </a>
                )}
              </div>
            </div>

            {item.data.proofPoints.length > 0 && (
              <div class="grid gap-3 sm:grid-cols-2">
                {item.data.proofPoints.map((point) => (
                  <div class="rounded-site-lg border border-site-border bg-site-control-bg p-4">
                    <Icon name="mdi:check-circle-outline" class="mb-3 h-5 w-5 text-site-accent" />
                    <p class="text-sm leading-6 text-site-text-muted">{point}</p>
                  </div>
                ))}
              </div>
            )}
          </div>
        </section>
      )}

      {item.data.episodeLinks.length > 0 && (
        <section class="mb-16" data-pagefind-ignore>
          <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <span class="site-kicker">Selected episodes</span>
              <h2 class="site-section-title mt-4">A look at the published run.</h2>
            </div>
            {item.data.channelUrl && (
              <a
                href={item.data.channelUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="site-link inline-flex items-center gap-2 text-sm font-semibold"
              >
                See all videos
                <Icon name="mdi:arrow-top-right" class="h-4 w-4" />
              </a>
            )}
          </div>

          <div class="site-grid-3">
            {item.data.episodeLinks.map((episode) => (
              <a
                href={episode.url ?? `https://youtu.be/${episode.videoId}`}
                target="_blank"
                rel="noopener noreferrer"
                class="site-card site-card-interactive group"
              >
                <div class="site-card-media aspect-video">
                  <img
                    src={`https://img.youtube.com/vi/${episode.videoId}/maxresdefault.jpg`}
                    alt={episode.title}
                    width="1280"
                    height="720"
                    loading="lazy"
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
                  />
                  <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/75 to-transparent"></div>
                  <span class="site-badge-overlay absolute left-4 top-4">Episode</span>
                </div>
                <div class="site-card-body-compact">
                  <h3 class="site-card-title">{episode.title}</h3>
                  <div class="site-meta-row">
                    <span>Watch on YouTube</span>
                    <Icon name="mdi:arrow-top-right" class="h-4 w-4" />
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      {item.data.gallery && item.data.gallery.length > 0 && (
        <section class="mb-16">
          <div class="mb-6">
            <span class="site-kicker">Gallery</span>
            <h2 class="site-section-title mt-4">Event gallery</h2>
          </div>
          <Gallery
            images={item.data.gallery.map((img) => ({
              src: img,
              alt: item.data.title,
            }))}
          />
        </section>
      )}

      <section class="site-panel mb-16 p-6 sm:p-8">
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
              Client
            </p>
            <p class="mt-3 text-base text-site-text">{item.data.clientName}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
              Category
            </p>
            <p class="mt-3 text-base text-site-text">{item.data.category}</p>
          </div>
        </div>

        {gearUsed.length > 0 && (
          <div class="mt-8">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
              Equipment Used
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              {gearUsed.map((gear) => (
                <a
                  href={`${base}gear/${gear.id}`}
                  class="site-chip site-chip-muted"
                >
                  <Icon name="mdi:camera-outline" class="h-4 w-4 text-site-accent" />
                  <span class="normal-case tracking-normal text-sm text-site-text-muted">
                    {gear.data.title}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}
      </section>

      {relatedServices.length > 0 && (
        <section class="border-t border-site-border py-16 sm:py-24" data-pagefind-ignore>
          <div class="mb-8">
            <span class="site-kicker">
              {relatedServices.length === 1 ? "Related service" : "Related services"}
            </span>
            <h2 class="site-section-title mt-4 max-w-3xl">Book the setup behind this project</h2>
            <p class="site-section-copy mt-4">
              This project reflects the workflow, gear, and production support behind the
              service{relatedServices.length === 1 ? "" : "s"} below.
            </p>
          </div>

          <div
            class:list={[
              "grid gap-6",
              relatedServices.length > 1 && "site-grid-2",
            ]}
          >
            {relatedServices.map((service) => (
              <ServicePreviewCard
                service={service}
                href={`${base}services/${service.id}`}
                variant={relatedServices.length === 1 ? "wide" : "default"}
              />
            ))}
          </div>
        </section>
      )}

      {relatedItems.length > 0 && (
        <section data-pagefind-ignore>
          <div class="mb-8">
            <span class="site-kicker">Related</span>
            <h2 class="site-section-title mt-4">Related projects</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {relatedItems.map((related) => (
              <a
                href={`${base}portfolio/${related.id}`}
                class="site-card site-card-interactive group"
              >
                <div class="site-card-media">
                  {related.data.image ? (
                    <Image
                      src={related.data.image}
                      alt={related.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  ) : related.data.videoId ? (
                    <img
                      src={`https://img.youtube.com/vi/${related.data.videoId}/maxresdefault.jpg`}
                      alt={related.data.title}
                      width="1280"
                      height="720"
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  ) : null}
                </div>
                <div class="site-card-body">
                  <h3 class="site-card-title">{related.data.title}</h3>
                  <div class="site-meta-row">
                    <span>{related.data.clientName}</span>
                    <span>View project</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>
