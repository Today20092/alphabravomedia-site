---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntries } from "astro:content";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const items = await getCollection("portfolio");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const gearUsedRaw = item.data.gearUsed
  ? await getEntries(item.data.gearUsed)
  : [];
const gearUsed = gearUsedRaw.filter((gear) => gear !== undefined);
if (gearUsedRaw.some((g) => g === undefined)) {
  console.warn(
    `Some gear items could not be resolved in ${item.data.title}. Provided IDs:`,
    item.data.gearUsed,
  );
}

// Get related items (same category, excluding current)
const allItems = await getCollection("portfolio");
const relatedItems = allItems
  .filter((i) => i.slug !== item.slug && i.data.category === item.data.category)
  .slice(0, 2);
---

<BaseLayout title={`${item.data.title} | Alpha Bravo Media`}>
  <article data-pagefind-body class="pt-32 pb-24 px-6">
    <span data-pagefind-meta="type" class="sr-only">Portfolio</span>
    <span data-pagefind-meta="client" style="display:none"
      >{item.data.clientName}</span
    >
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a
        href={`${base}portfolio`}
        class="inline-flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors mb-8"
      >
        <Icon name="mdi:arrow-left" class="w-4 h-4" />
        Back to Portfolio
      </a>

      <!-- Header -->
      <header class="mb-10">
        <span
          class="inline-block px-3 py-1 bg-[#c8875c]/10 rounded-full text-xs font-medium text-[#c8875c] mb-4"
        >
          {item.data.category}
        </span>
        <h1
          class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white mb-4 font-['Sora',sans-serif]"
        >
          {item.data.title}
        </h1>
        <p class="text-lg text-[#a8998a]">
          Client: <span class="text-white">{item.data.clientName}</span>
        </p>
      </header>

      <!-- Video Embed or Image -->
      {
        (item.data.videoId || item.data.image) && (
          <div class="relative group mb-12">
            <div class="absolute -inset-4 bg-linear-to-r from-[#c8875c]/10 to-[#a06b3e]/10 rounded-3xl blur-2xl opacity-50" />
            <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50 bg-[#141211] border border-[#2a2520] flex items-center justify-center">
              {item.data.videoId ? (
                <YouTube
                  id={item.data.videoId}
                  class="w-full max-w-full aspect-video m-0"
                />
              ) : item.data.image ? (
                <Image
                  src={item.data.image}
                  alt={item.data.title}
                  class="w-full aspect-video object-cover"
                />
              ) : null}
            </div>
          </div>
        )
      }

      <!-- Content -->
      <div class="prose prose-invert prose-lg max-w-none mb-16">
        <Content />
      </div>

      <!-- Project Details -->
      <div class="border-t border-[#2a2520] pt-8 mb-16">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <h3
              class="text-xs font-semibold text-[#7a6f63] uppercase tracking-wider mb-2"
            >
              Client
            </h3>
            <p class="text-white">{item.data.clientName}</p>
          </div>
          <div>
            <h3
              class="text-xs font-semibold text-[#7a6f63] uppercase tracking-wider mb-2"
            >
              Category
            </h3>
            <p class="text-white">{item.data.category}</p>
          </div>
        </div>

        {
          gearUsed.length > 0 && (
            <div class="mt-8">
              <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-4">
                Equipment Used
              </h3>
              <div class="flex flex-wrap gap-2">
                {gearUsed.map((gear) => (
                  <a
                    href={`${base}gear/${gear.slug}`}
                    class="inline-flex items-center px-4 py-2 bg-[#141211] border border-[#2a2520] rounded-lg text-sm text-[#a8998a] hover:text-white hover:border-[#c8875c]/50 hover:bg-[#c8875c]/10 transition-all duration-300"
                  >
                    <Icon
                      name="mdi:camera"
                      class="w-4 h-4 mr-2 text-[#c8875c]"
                    />
                    {gear.data.title}
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>

      <!-- Related Projects -->
      {
        relatedItems.length > 0 && (
          <div data-pagefind-ignore class="border-t border-[#2a2520] pt-12">
            <h2 class="text-2xl font-bold text-white mb-8 font-['Sora',sans-serif]">Related Projects</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              {relatedItems.map((related) => (
                <a
                  href={`${base}portfolio/${related.slug}`}
                  class="group relative bg-[#141211] rounded-xl overflow-hidden border border-[#2a2520] transition-all duration-300 hover:scale-[1.02] hover:border-[#c8875c]/30"
                >
                  <div class="aspect-video bg-linear-to-br from-gray-800 to-gray-900 relative overflow-hidden">
                    {related.data.image ? (
                      <Image
                        src={related.data.image}
                        alt={related.data.title}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : related.data.videoId ? (
                      <img
                        src={`https://img.youtube.com/vi/${related.data.videoId}/maxresdefault.jpg`}
                        alt={related.data.title}
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : null}
                    <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent" />
                  </div>
                  <div class="p-5">
                    <h3 class="text-lg font-semibold text-white group-hover:text-gray-200 transition-colors">
                      {related.data.title}
                    </h3>
                    <p class="text-sm text-[#7a6f63] mt-1">
                      {related.data.clientName}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
