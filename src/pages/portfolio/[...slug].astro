---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, getEntries } from "astro:content";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import Gallery from "../../components/Gallery.astro";

export async function getStaticPaths() {
  const items = await getCollection("portfolio");
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const gearUsedRaw = item.data.gearUsed ? await getEntries(item.data.gearUsed) : [];
const gearUsed = gearUsedRaw.filter((gear) => gear !== undefined);
if (gearUsedRaw.some((g) => g === undefined)) {
  console.warn(
    `Some gear items could not be resolved in ${item.data.title}. Provided IDs:`,
    item.data.gearUsed,
  );
}

const allItems = await getCollection("portfolio");
const relatedItems = allItems
  .filter((i) => i.slug !== item.slug && i.data.category === item.data.category)
  .slice(0, 2);
---

<BaseLayout title={`${item.data.title} | Alpha Bravo Media`}>
  <article data-pagefind-body class="px-6 pb-24 pt-32">
    <span data-pagefind-meta="type" class="sr-only">Portfolio</span>
    <span data-pagefind-meta="client" style="display:none">{item.data.clientName}</span>

    <div class="site-shell">
      <a href={`${base}portfolio`} class="site-link inline-flex items-center gap-2 text-sm">
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        Back to Portfolio
      </a>

      <header class="site-page-header mt-8">
        <span class="site-chip">{item.data.category}</span>
        <h1 class="site-page-title max-w-4xl">{item.data.title}</h1>
        <div class="site-meta-row">
          <span>Client</span>
          <span class="text-[var(--site-text)]">{item.data.clientName}</span>
        </div>
      </header>

      {(item.data.videoId || item.data.facebookUrl || item.data.image) && (
        <div class="site-card mb-12 overflow-hidden">
          <div class="site-card-media aspect-video flex items-center justify-center">
            {item.data.videoId ? (
              <YouTube id={item.data.videoId} class="m-0 w-full max-w-full aspect-video" />
            ) : item.data.facebookUrl ? (
              <iframe
                src={`https://www.facebook.com/plugins/video.php?href=${encodeURIComponent(item.data.facebookUrl)}&show_text=0&t=0`}
                class="w-full aspect-video border-none overflow-hidden"
                scrolling="no"
                frameborder="0"
                allowfullscreen="true"
                allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
              />
            ) : item.data.image ? (
              <Image
                src={item.data.image}
                alt={item.data.title}
                class="h-full w-full object-cover"
              />
            ) : null}
          </div>
        </div>
      )}

      <div
        class="site-prose prose prose-invert md:prose-lg max-w-none mb-16 prose-headings:text-balance prose-h1:text-3xl md:prose-h1:text-4xl prose-h2:text-2xl md:prose-h2:text-3xl prose-h3:text-xl md:prose-h3:text-2xl"
      >
        <Content />
      </div>

      {item.data.gallery && item.data.gallery.length > 0 && (
        <section class="mb-16">
          <div class="mb-6">
            <span class="site-kicker">Gallery</span>
            <h2 class="site-section-title mt-4">Event gallery</h2>
          </div>
          <Gallery
            images={item.data.gallery.map((img) => ({
              src: img,
              alt: item.data.title,
            }))}
          />
        </section>
      )}

      <section class="site-panel mb-16 p-6 sm:p-8">
        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
              Client
            </p>
            <p class="mt-3 text-base text-[var(--site-text)]">{item.data.clientName}</p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
              Category
            </p>
            <p class="mt-3 text-base text-[var(--site-text)]">{item.data.category}</p>
          </div>
        </div>

        {gearUsed.length > 0 && (
          <div class="mt-8">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
              Equipment Used
            </p>
            <div class="mt-4 flex flex-wrap gap-3">
              {gearUsed.map((gear) => (
                <a
                  href={`${base}gear/${gear.slug}`}
                  class="site-chip site-chip-muted"
                >
                  <Icon name="mdi:camera-outline" class="h-4 w-4 text-[var(--site-accent)]" />
                  <span class="normal-case tracking-normal text-sm text-[var(--site-text-muted)]">
                    {gear.data.title}
                  </span>
                </a>
              ))}
            </div>
          </div>
        )}
      </section>

      {relatedItems.length > 0 && (
        <section data-pagefind-ignore>
          <div class="mb-8">
            <span class="site-kicker">Related</span>
            <h2 class="site-section-title mt-4">Related projects</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {relatedItems.map((related) => (
              <a
                href={`${base}portfolio/${related.slug}`}
                class="site-card site-card-interactive group"
              >
                <div class="site-card-media">
                  {related.data.image ? (
                    <Image
                      src={related.data.image}
                      alt={related.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  ) : related.data.videoId ? (
                    <img
                      src={`https://img.youtube.com/vi/${related.data.videoId}/maxresdefault.jpg`}
                      alt={related.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  ) : null}
                </div>
                <div class="site-card-body">
                  <h3 class="site-card-title">{related.data.title}</h3>
                  <div class="site-meta-row">
                    <span>{related.data.clientName}</span>
                    <span>View project</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>
