---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allItems = (await getCollection("portfolio")).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = [...new Set(allItems.map((item) => item.data.category))];
---

<BaseLayout title="Portfolio | Alpha Bravo Media">
  <section class="px-6 pb-24 pt-32">
    <div class="site-shell">
      <div class="site-page-header">
        <span class="site-kicker">Portfolio</span>
        <h1 class="site-page-title">Selected work across client, creator, and event projects.</h1>
        <p class="site-page-copy text-lg">
          A focused look at the projects, outcomes, and production standards behind the
          work.
        </p>
      </div>

      {categories.length > 0 && (
        <div class="mb-10 flex flex-wrap gap-3">
          <button
            class="filter-btn site-chip active"
            data-category="all"
          >
            All
          </button>
          {categories.map((category) => (
            <button
              class="filter-btn site-chip site-chip-muted"
              data-category={category}
            >
              {category}
            </button>
          ))}
        </div>
      )}

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3" id="portfolio-grid">
        {allItems.map((item) => (
          <a
            href={`${base}portfolio/${item.slug}`}
            class="portfolio-item site-card site-card-interactive group"
            data-category={item.data.category}
          >
            <div class="site-card-media">
              {(() => {
                const thumbImage = item.data.image;
                const youtubeUrl = item.data.videoId
                  ? `https://img.youtube.com/vi/${item.data.videoId}/maxresdefault.jpg`
                  : null;
                const facebookUrl = item.data.facebookUrl;

                if (thumbImage) {
                  return (
                    <Image
                      src={thumbImage}
                      alt={item.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                if (youtubeUrl) {
                  return (
                    <img
                      src={youtubeUrl}
                      alt={item.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                if (facebookUrl) {
                  return (
                    <div class="flex h-full items-center justify-center text-[var(--site-text-soft)]">
                      <Icon name="mdi:facebook" class="h-10 w-10" />
                    </div>
                  );
                }

                return null;
              })()}
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/70 to-transparent"></div>
              <span class="site-chip absolute left-4 top-4">{item.data.category}</span>
            </div>

            <div class="site-card-body">
              <h2 class="site-card-title">{item.data.title}</h2>
              <div class="site-meta-row">
                <span>{item.data.clientName}</span>
                <span>View project</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      {allItems.length === 0 && (
        <div class="site-panel-muted mt-10 px-6 py-16 text-center">
          <p class="text-lg text-[var(--site-text)]">No portfolio items yet.</p>
          <p class="mt-3 text-sm text-[var(--site-text-soft)]">Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn.active {
    border-color: rgba(200, 135, 92, 0.24);
    background: rgba(200, 135, 92, 0.12);
    color: var(--site-accent);
  }

  .portfolio-item.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(".portfolio-item");

    if (!filterBtns.length || !items.length) return;

    function filterPortfolio(category: string | null) {
      if (!category) return;

      filterBtns.forEach((b) => b.classList.remove("active"));
      const targetBtn =
        Array.from(filterBtns).find(
          (b) => b.getAttribute("data-category") === category,
        ) || filterBtns[0];
      if (targetBtn) targetBtn.classList.add("active");

      items.forEach((item) => {
        const itemCategory = item.getAttribute("data-category");
        if (category === "all" || itemCategory === category) {
          item.classList.remove("hidden");
        } else {
          item.classList.add("hidden");
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");
        filterPortfolio(category);

        const url = new URL(window.location.href);
        if (category === "all") {
          url.searchParams.delete("category");
        } else if (category) {
          url.searchParams.set("category", category);
        }
        window.history.pushState({}, "", url);
      });
    });

    const params = new URLSearchParams(window.location.search);
    const initialCategory = params.get("category");
    if (initialCategory) filterPortfolio(initialCategory);
  });
</script>
