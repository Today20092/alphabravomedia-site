---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allItems = (await getCollection("portfolio")).sort(
  (a, b) => a.data.order - b.data.order,
);

const categories = [...new Set(allItems.map((item) => item.data.category))];
---

<BaseLayout
  title="Selected Work | Alpha Bravo Media"
  description="Selected work across brand video, podcasts, weddings, and live productions."
>
  <section class="site-section-hero">
    <div class="site-shell">
      <div class="space-y-10">
        <div class="site-page-header mb-0">
          <span class="site-kicker">Work</span>
          <h1 class="site-page-title">Selected work across client, creator, and event projects.</h1>
          <p class="site-page-copy text-lg">
            A focused look at the projects, outcomes, and production standards behind the
            work.
          </p>
        </div>

        {categories.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-3 sm:mt-5">
            <button
              class="filter-btn site-chip active"
              data-category="all"
            >
              All
            </button>
            {categories.map((category) => (
              <button
                class="filter-btn site-chip site-chip-muted"
                data-category={category}
              >
                {category}
              </button>
            ))}
          </div>
        )}

        <div class="site-grid-3" id="portfolio-grid">
          {allItems.map((item) => (
            <a
              href={`${base}portfolio/${item.slug}`}
              class="portfolio-item site-card site-card-interactive group"
              data-category={item.data.category}
            >
              <div class="site-card-media">
                {(() => {
                  const thumbImage = item.data.image;
                  const youtubeUrl = item.data.videoId
                    ? `https://img.youtube.com/vi/${item.data.videoId}/maxresdefault.jpg`
                    : null;
                  const facebookUrl = item.data.facebookUrl;

                  if (thumbImage) {
                    return (
                      <Image
                        src={thumbImage}
                        alt={item.data.title}
                        class="absolute inset-0 h-full w-full object-cover"
                      />
                    );
                  }

                  if (youtubeUrl) {
                    return (
                      <img
                        src={youtubeUrl}
                        alt={item.data.title}
                        width="1280"
                        height="720"
                        class="absolute inset-0 h-full w-full object-cover"
                      />
                    );
                  }

                  if (facebookUrl) {
                    return (
                      <div class="flex h-full items-center justify-center text-site-text-soft">
                        <Icon name="mdi:facebook" class="h-10 w-10" />
                      </div>
                    );
                  }

                  return null;
                })()}
                <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/70 to-transparent"></div>
                <span class="site-badge-overlay absolute left-4 top-4">
                  {item.data.category}
                </span>
              </div>

              <div class="site-card-body">
                <h2 class="site-card-title">{item.data.title}</h2>
                <div class="site-meta-row">
                  <span>{item.data.clientName || "Selected work"}</span>
                  <span>View work</span>
                </div>
                {item.data.outcome && (
                  <p class="site-card-copy line-clamp-2">{item.data.outcome}</p>
                )}
              </div>
            </a>
          ))}
        </div>

        {allItems.length === 0 && (
          <div class="site-panel-muted px-6 py-16 text-center">
            <p class="text-lg text-site-text">No work items yet.</p>
            <p class="mt-3 text-sm text-site-text-soft">Check back soon.</p>
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .filter-btn.active {
    border-color: color-mix(in oklab, var(--site-accent) 28%, transparent);
    background: var(--site-accent-soft);
    color: var(--site-accent);
  }

  html[data-theme="light"] .filter-btn.site-chip-muted {
    border-color: var(--site-border-strong);
    background: color-mix(in oklab, var(--site-surface) 88%, var(--site-text) 12%);
    color: var(--site-text);
  }

  html[data-theme="light"] .filter-btn.site-chip-muted:hover {
    background: color-mix(in oklab, var(--site-surface) 80%, var(--site-text) 20%);
  }

  .portfolio-item.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const filterBtns = document.querySelectorAll(".filter-btn");
    const items = document.querySelectorAll(".portfolio-item");

    if (!filterBtns.length || !items.length) return;

    function filterPortfolio(category: string | null) {
      if (!category) return;

      filterBtns.forEach((b) => b.classList.remove("active"));
      const targetBtn =
        Array.from(filterBtns).find(
          (b) => b.getAttribute("data-category") === category,
        ) || filterBtns[0];
      if (targetBtn) targetBtn.classList.add("active");

      items.forEach((item) => {
        const itemCategory = item.getAttribute("data-category");
        if (category === "all" || itemCategory === category) {
          item.classList.remove("hidden");
        } else {
          item.classList.add("hidden");
        }
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const category = btn.getAttribute("data-category");
        filterPortfolio(category);

        const url = new URL(window.location.href);
        if (category === "all") {
          url.searchParams.delete("category");
        } else if (category) {
          url.searchParams.set("category", category);
        }
        window.history.pushState({}, "", url);
      });
    });

    const params = new URLSearchParams(window.location.search);
    const initialCategory = params.get("category");
    if (initialCategory) filterPortfolio(initialCategory);
  });
</script>
