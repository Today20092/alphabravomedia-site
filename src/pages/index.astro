---
import BaseLayout from "../layouts/BaseLayout.astro";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import ServicesTeaser from "../components/ServicesTeaser.astro";
import GoogleReviewsBand from "../components/GoogleReviewsBand.astro";
import WorkCard from "../components/WorkCard.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allPortfolio = await getCollection("portfolio");
const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
const monthlyService = sortedServices.find((service) => service.id === "monthly-retainers");

function resolveWork(refs: string[]) {
  return refs
    .map((ref) =>
      allPortfolio.find(
        (item) =>
          item.id.toLowerCase().endsWith(ref.toLowerCase()),
      ),
    )
    .filter(Boolean);
}

const featuredWork = resolveWork([
  "erchid-law-firm",
  "rizq-mdjd-podcast",
  "ensuring-every-word-matters",
]);
---

<BaseLayout
  title="Tampa Content Retainers and Video Production | Alpha Bravo Media"
  description="Outcome-first content production for Tampa businesses that need stronger trust, clearer messaging, and a consistent stream of polished media."
>
  <section class="site-section-hero relative isolate overflow-hidden">
    <div class="site-atmosphere-hero" aria-hidden="true"></div>
    <div class="site-vignette-frame" aria-hidden="true"></div>
    <div class="site-texture-grain" aria-hidden="true"></div>

    <div class="site-shell relative">
      <div class="grid gap-12 lg:grid-cols-[minmax(0,1.02fr)_minmax(22rem,0.98fr)] lg:items-center xl:gap-18">
        <div class="site-page-header mb-0 max-w-4xl">
          <span class="site-kicker site-reveal" data-reveal>Alpha Bravo Media</span>
          <h1 class="site-page-title site-reveal site-reveal-stagger-1" data-reveal>
            Content that makes your business look credible, communicate clearly,
            and stay visible.
          </h1>
          <p class="site-page-copy site-reveal site-reveal-stagger-2 text-base sm:text-lg" data-reveal>
            Strategy, filming, editing, photography, and repurposing handled by one
            production partner. Monthly retainers lead the offer when consistency is
            the real bottleneck.
          </p>
          <div class="site-reveal site-reveal-stagger-2 mt-6 flex flex-wrap gap-3 text-sm text-site-text-muted" data-reveal>
            <span class="site-chip">Starting at $1,200/mo</span>
            <span class="site-chip site-chip-muted">Honest fit guidance before booking</span>
            <span class="site-chip site-chip-muted">Reasonable revisions after delivery</span>
          </div>
          <div class="site-reveal site-reveal-stagger-3 mt-8 flex flex-col gap-3 sm:flex-row" data-reveal>
            <a href={`${base}services/monthly-retainers`} class="site-button-primary site-hover-lift">
              See monthly retainers
            </a>
            <a href={`${base}portfolio`} class="site-button-secondary site-hover-lift">
              Browse work
            </a>
          </div>
          <p class="site-reveal site-reveal-stagger-3 mt-5 max-w-2xl text-sm leading-6 text-site-text-soft sm:text-base" data-reveal>
            Ayoub texts first, makes sure the project is a fit, and gives a clear next
            step before you commit to production.
          </p>
        </div>

        <div class="site-reveal site-reveal-stagger-3 relative grid gap-4 lg:pt-2 xl:pt-0" data-reveal>
          <div class="site-panel-muted site-hover-lift ml-auto w-full max-w-[25rem] overflow-hidden p-5 sm:p-6">
            <div class="grid gap-4 sm:grid-cols-[minmax(0,1fr)_10.5rem] sm:items-center">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
                  First call structure
                </p>
                <p class="mt-3 max-w-md text-sm leading-6 text-site-text">
                  Fit gets clarified first. Scope comes next. Production starts after both are clean.
                </p>
              </div>
              <div class="rounded-site-lg border border-site-border bg-site-surface px-4 py-5 shadow-site-sm">
                <svg viewBox="0 0 220 96" class="h-20 w-full text-site-accent" aria-hidden="true">
                  <path
                    d="M20 70C44 49 62 37 84 37C105 37 120 59 142 59C162 59 179 42 199 22"
                    fill="none"
                    stroke="currentColor"
                    stroke-linecap="round"
                    stroke-width="4"
                    opacity="0.82"
                  ></path>
                  <circle cx="20" cy="70" r="7" fill="currentColor" opacity="0.28"></circle>
                  <circle cx="109" cy="48" r="7" fill="currentColor" opacity="0.5"></circle>
                  <circle cx="199" cy="22" r="7" fill="currentColor" opacity="0.82"></circle>
                  <g fill="currentColor" font-size="11" font-weight="700" letter-spacing="0.14em">
                    <text x="4" y="92">FIT</text>
                    <text x="88" y="92">SCOPE</text>
                    <text x="168" y="92">SHOOT</text>
                  </g>
                </svg>
              </div>
            </div>
          </div>

          <div class="relative lg:-ml-10 xl:-ml-14">
            <div class="site-card site-hover-lift overflow-hidden shadow-site-md">
              <div class="site-card-media aspect-video">
                <YouTube id="wXsf-nbHbzU" class="m-0 w-full max-w-full aspect-video" />
              </div>
              <div class="grid gap-3 border-t border-site-border bg-site-surface p-5 sm:grid-cols-3">
                <div class="site-panel-muted p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
                    Outcome
                  </p>
                  <p class="mt-3 text-sm leading-6 text-site-text">
                    Make the business feel more trustworthy before the first call.
                  </p>
                </div>
                <div class="site-panel-muted p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
                    Mechanism
                  </p>
                  <p class="mt-3 text-sm leading-6 text-site-text">
                    Recurring shoot days, editing, repurposing, and delivery-ready assets.
                  </p>
                </div>
                <div class="site-panel-muted p-4">
                  <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
                    Fit promise
                  </p>
                  <p class="mt-3 text-sm leading-6 text-site-text">
                    If the job is not the right fit, you will hear that before anything gets booked.
                  </p>
                </div>
              </div>
            </div>
            <div class="site-panel site-hover-lift absolute -left-8 bottom-8 hidden w-56 p-5 xl:block">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
                Why this feels lower risk
              </p>
              <p class="mt-3 text-sm leading-6 text-site-text">
                No package gets pushed until the call confirms the business actually needs this.
              </p>
              <div class="mt-4 flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-site-accent">
                <span class="h-2 w-2 rounded-full bg-site-accent"></span>
                Fit before invoice
              </div>
            </div>
            <div class="pointer-events-none absolute -right-3 top-24 hidden h-28 w-28 rounded-full border border-site-border bg-site-surface/70 blur-2xl xl:block"></div>
            <div class="pointer-events-none absolute left-12 top-10 hidden h-px w-28 bg-gradient-to-r from-site-accent/50 to-transparent xl:block"></div>
            <div class="pointer-events-none absolute right-8 top-3 hidden text-[0.68rem] font-semibold uppercase tracking-[0.28em] text-site-text-soft xl:block">
              Editorial proof
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="site-section relative isolate overflow-hidden">
    <div class="site-atmosphere-section" aria-hidden="true"></div>

    <div class="site-shell relative">
      <div class="mb-10 grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(19rem,0.76fr)] lg:items-start">
        <div class="max-w-3xl">
          <span class="site-kicker site-reveal" data-reveal>Outcomes first</span>
          <h2 class="site-section-title site-reveal site-reveal-stagger-1 mt-4" data-reveal>
            Alpha Bravo Media helps businesses look established, attract the right
            audience, and turn content into real growth.
          </h2>
          <p class="site-reveal site-reveal-stagger-2 mt-4 max-w-2xl text-sm leading-7 text-site-text-muted" data-reveal>
            We do more than show up with cameras. We help clients build trust faster,
            explain what makes them different, stay visible online, and use modern
            content systems, including AI, to market more consistently.
          </p>
        </div>

        <div class="site-panel site-reveal site-reveal-stagger-2 relative mt-3 overflow-hidden p-5 sm:mt-4 sm:p-6" data-reveal>
          <div class="absolute inset-0 bg-gradient-to-br from-site-accent/10 via-transparent to-site-accent/5"></div>
          <div class="relative">
            <div class="mb-4 flex flex-wrap gap-2 text-[11px] font-semibold uppercase tracking-[0.22em] text-site-text-soft">
              <span class="rounded-full border border-site-border bg-site-surface/80 px-3 py-1">Trust</span>
              <span class="rounded-full border border-site-border bg-site-surface/80 px-3 py-1">Authority</span>
              <span class="rounded-full border border-site-border bg-site-surface/80 px-3 py-1">Reach</span>
              <span class="rounded-full border border-site-border bg-site-surface/80 px-3 py-1">AI systems</span>
            </div>

            <svg
              viewBox="0 0 520 360"
              class="w-full text-site-accent"
              aria-hidden="true"
              fill="none"
            >
              <defs>
                <linearGradient id="outcomes-path" x1="64" y1="278" x2="450" y2="86" gradientUnits="userSpaceOnUse">
                  <stop stop-color="currentColor" stop-opacity="0.16"></stop>
                  <stop offset="0.5" stop-color="currentColor" stop-opacity="0.62"></stop>
                  <stop offset="1" stop-color="currentColor" stop-opacity="0.28"></stop>
                </linearGradient>
                <radialGradient id="outcomes-aura" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate(426 78) rotate(90) scale(120 120)">
                  <stop stop-color="currentColor" stop-opacity="0.16"></stop>
                  <stop offset="1" stop-color="currentColor" stop-opacity="0"></stop>
                </radialGradient>
              </defs>

              <rect x="18" y="18" width="484" height="324" rx="28" stroke="currentColor" stroke-opacity="0.12"></rect>
              <circle cx="426" cy="78" r="120" fill="url(#outcomes-aura)" class="text-site-accent"></circle>
              <path
                d="M62 278C131 240 180 242 241 210C296 181 346 141 456 86"
                stroke="url(#outcomes-path)"
                stroke-width="8"
                stroke-linecap="round"
              ></path>

              <g class="text-site-text">
                <rect x="52" y="156" width="124" height="110" rx="24" fill="currentColor" fill-opacity="0.03" stroke="currentColor" stroke-opacity="0.12"></rect>
                <rect x="198" y="126" width="124" height="110" rx="24" fill="currentColor" fill-opacity="0.03" stroke="currentColor" stroke-opacity="0.12"></rect>
                <rect x="344" y="92" width="124" height="110" rx="24" fill="currentColor" fill-opacity="0.03" stroke="currentColor" stroke-opacity="0.12"></rect>
              </g>

              <g class="text-site-accent">
                <circle cx="114" cy="210" r="26" stroke="currentColor" stroke-width="2.5" stroke-opacity="0.7"></circle>
                <path d="M100 210H128" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
                <path d="M114 196V224" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>

                <path d="M226 194C241 177 278 177 294 194" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-opacity="0.85"></path>
                <path d="M220 208H300" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-opacity="0.65"></path>
                <path d="M236 222H286" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-opacity="0.45"></path>

                <circle cx="406" cy="147" r="28" stroke="currentColor" stroke-width="2.5" stroke-opacity="0.75"></circle>
                <circle cx="406" cy="147" r="15" stroke="currentColor" stroke-width="2.5"></circle>
                <circle cx="406" cy="147" r="4.5" fill="currentColor"></circle>
              </g>

              <g class="text-site-text-soft">
                <path d="M62 294H456" stroke="currentColor" stroke-opacity="0.2"></path>
                <circle cx="114" cy="210" r="6" fill="currentColor"></circle>
                <circle cx="260" cy="194" r="6" fill="currentColor"></circle>
                <circle cx="406" cy="147" r="6" fill="currentColor"></circle>
              </g>
            </svg>
          </div>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <div class="site-panel site-hover-lift site-reveal relative overflow-hidden p-6 sm:p-8" data-reveal>
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-site-border bg-site-surface text-site-accent shadow-site-sm">
            <svg viewBox="0 0 48 48" class="h-7 w-7" aria-hidden="true" fill="none">
              <circle cx="24" cy="24" r="15" stroke="currentColor" stroke-width="2.5"></circle>
              <path d="M24 14V34" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
              <path d="M14 24H34" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-site-text">Earn trust and win more leads</p>
          <p class="mt-3 text-sm leading-7 text-site-text-muted">
            Strong visuals, clear messaging, and polished presentation help the business
            look established online so more of the right people feel confident reaching out.
          </p>
        </div>
        <div class="site-panel site-hover-lift site-reveal site-reveal-stagger-1 relative overflow-hidden p-6 sm:p-8" data-reveal>
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-site-border bg-site-surface text-site-accent shadow-site-sm">
            <svg viewBox="0 0 48 48" class="h-7 w-7" aria-hidden="true" fill="none">
              <path d="M10 30C14 19 20 14 28 14C35 14 39 18 39 25C39 32 34 36 25 36H17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M15 20H28" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
              <path d="M15 26H24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-site-text">Build authority in the market</p>
          <p class="mt-3 text-sm leading-7 text-site-text-muted">
            Content is used to show expertise, answer common questions, explain the offer
            clearly, and position the business as the trusted choice in its field.
          </p>
        </div>
        <div class="site-panel site-hover-lift site-reveal site-reveal-stagger-2 relative overflow-hidden p-6 sm:p-8" data-reveal>
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-2xl border border-site-border bg-site-surface text-site-accent shadow-site-sm">
            <svg viewBox="0 0 48 48" class="h-7 w-7" aria-hidden="true" fill="none">
              <circle cx="14" cy="24" r="4" fill="currentColor"></circle>
              <circle cx="34" cy="14" r="4" fill="currentColor"></circle>
              <circle cx="34" cy="34" r="4" fill="currentColor"></circle>
              <path d="M18 24H30" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
              <path d="M17 22L30 15" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
              <path d="M17 26L30 33" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"></path>
            </svg>
          </div>
          <p class="text-sm font-semibold text-site-text">Reach more people with less friction</p>
          <p class="mt-3 text-sm leading-7 text-site-text-muted">
            We handle planning, production, editing, repurposing, and practical AI support
            so marketing keeps moving, reaches the target audience, and does not depend on
            the client doing everything manually.
          </p>
        </div>
      </div>
    </div>
  </section>

  {monthlyService && (
    <section class="site-section">
      <div class="site-shell">
        <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.92fr)] lg:items-center">
          <div>
            <span class="site-kicker site-reveal" data-reveal>Main offer</span>
            <h2 class="site-section-title site-reveal site-reveal-stagger-1 mt-4" data-reveal>
              Monthly content retainers for businesses that need momentum, not one-off media.
            </h2>
            <p class="site-section-copy site-reveal site-reveal-stagger-2 mt-4" data-reveal>
              Recurring strategy and production usually create better results than isolated
              shoots. The retainer is built for businesses that want steady publishing,
              stronger positioning, and a partner who can help shape the message.
            </p>
            <div class="site-reveal site-reveal-stagger-2 mt-6 flex flex-wrap gap-3" data-reveal>
              <span class="site-chip">Starting at $1,200/mo</span>
              <span class="site-chip site-chip-muted">Most popular: Growth Retainer</span>
            </div>
            <ul class="mt-8 space-y-3">
              {monthlyService.data.tiers[1]?.value?.includes.slice(0, 4).map((item: string, index: number) => (
                <li
                  class:list={[
                    "site-reveal flex items-start gap-3 text-sm leading-7 text-site-text-muted",
                    index === 0 && "site-reveal-stagger-1",
                    index === 1 && "site-reveal-stagger-2",
                    index >= 2 && "site-reveal-stagger-3",
                  ]}
                  data-reveal
                >
                  <Icon name="mdi:check-circle" class="mt-1 h-4 w-4 shrink-0 text-site-accent" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <div class="site-reveal site-reveal-stagger-3 mt-8 flex flex-col gap-3 sm:flex-row" data-reveal>
              <a href={`${base}services/monthly-retainers`} class="site-button-primary site-hover-lift">
                See retainers and pricing
              </a>
              <a href={`${base}contact`} class="site-button-secondary site-hover-lift">
                Talk through fit first
              </a>
            </div>
          </div>

          <div class="site-card site-hover-lift site-reveal site-reveal-stagger-2 overflow-hidden" data-reveal>
            <div class="site-card-media aspect-[4/3]">
              {monthlyService.data.heroImage && (
                <img
                  src={monthlyService.data.heroImage.src}
                  alt={monthlyService.data.title}
                  class="absolute inset-0 h-full w-full object-cover"
                />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
              <span class="site-badge-overlay absolute left-4 top-4">Retainers</span>
              <div class="absolute bottom-5 left-5 right-5">
                <p class="max-w-sm font-['Sora',sans-serif] text-2xl font-semibold tracking-tight text-white">
                  Publish consistently with one team handling planning, capture, and edits.
                </p>
              </div>
            </div>
            <div class="site-card-body">
              <div class="site-meta-row">
                <span>Best for recurring content</span>
                <span>Growth-first offer</span>
              </div>
              <p class="site-card-copy">
                Use retainers when the business needs reels, brand photos, campaign support,
                and a steadier content system instead of another disconnected shoot day.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  {featuredWork.length > 0 && (
    <section class="site-section">
      <div class="site-shell">
        <div class="mb-8 flex items-end justify-between gap-4">
          <div class="site-page-header mb-0">
            <span class="site-kicker site-reveal" data-reveal>Proof</span>
            <h2 class="site-section-title site-reveal site-reveal-stagger-1" data-reveal>Real work tied to real service lines.</h2>
          </div>
          <a href={`${base}portfolio`} class="site-button-secondary site-hover-lift site-reveal site-reveal-stagger-2 hidden sm:inline-flex" data-reveal>
            Browse work
          </a>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          {featuredWork.map((item: any, index: number) => (
            <div
              class:list={[
                "site-reveal",
                index === 1 && "site-reveal-stagger-1",
                index === 2 && "site-reveal-stagger-2",
              ]}
              data-reveal
            >
              <WorkCard
                item={item}
                href={`${base}portfolio/${item.id}`}
                ctaLabel="See example"
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <ServicesTeaser
    excludeIds={["monthly-retainers"]}
    title="Supporting services when the job is podcast, event, or wedding specific."
    description="The recurring content offer leads the site, but podcast production, live event support, and weddings remain available when the brief needs a dedicated production block."
  />

  <section class="site-section">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,1.08fr)] lg:items-start">
        <div class="max-w-2xl">
          <span class="site-kicker site-reveal" data-reveal>Discovery before payment</span>
          <h2 class="site-section-title site-reveal site-reveal-stagger-1 mt-4" data-reveal>
            We figure out the right scope before you pay for the wrong package.
          </h2>
          <p class="site-section-copy site-reveal site-reveal-stagger-2 mt-4" data-reveal>
            The first conversation is a working fit check, not a pressure call. Ayoub helps
            you sort out what the business actually needs, recommends the right production
            path if it makes sense, and says so early if it does not. If another specialist
            is the better answer, he points you there before any invoice goes out.
          </p>
          <div class="mt-8 grid gap-4">
            <div class="site-reveal border-t border-site-border pt-4" data-reveal>
              <div class="flex items-start gap-3">
                <Icon name="mdi:account-search-outline" class="mt-0.5 h-5 w-5 text-site-accent" />
                <div>
                  <p class="text-sm font-semibold text-site-text">Free fit call first</p>
                  <p class="mt-2 text-sm leading-7 text-site-text-muted">
                    Goals, timing, budget, and deliverables get discussed before money changes hands.
                  </p>
                </div>
              </div>
            </div>
            <div class="site-reveal site-reveal-stagger-1 border-t border-site-border pt-4" data-reveal>
              <div class="flex items-start gap-3">
                <Icon name="mdi:clipboard-text-clock-outline" class="mt-0.5 h-5 w-5 text-site-accent" />
                <div>
                  <p class="text-sm font-semibold text-site-text">Clear scope before production</p>
                  <p class="mt-2 text-sm leading-7 text-site-text-muted">
                    Once the fit is clear, the shoot plan, delivery path, and revision window get defined.
                  </p>
                </div>
              </div>
            </div>
            <div class="site-reveal site-reveal-stagger-2 border-t border-site-border pt-4" data-reveal>
              <div class="flex items-start gap-3">
                <Icon name="mdi:handshake-outline" class="mt-0.5 h-5 w-5 text-site-accent" />
                <div>
                  <p class="text-sm font-semibold text-site-text">Referral out if it is not a match</p>
                  <p class="mt-2 text-sm leading-7 text-site-text-muted">
                    If the right answer is another specialist, you hear that early instead of being sold the wrong offer.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="grid gap-4">
          <div class="site-panel site-hover-lift site-reveal site-reveal-stagger-1 overflow-hidden p-6 sm:p-7" data-reveal>
            <div class="flex flex-col gap-6">
