---
import BaseLayout from '../layouts/BaseLayout.astro';
import { YouTube } from '@astro-community/astro-embed-youtube';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

// Get latest blog posts and portfolio pieces
const allBlogPosts = await getCollection('blog');
const allPortfolio = await getCollection('portfolio');

const latestBlog = allBlogPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestPortfolio = allPortfolio
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout>
  <!-- Hero Section -->
  <section class="min-h-screen flex items-center justify-center px-6 pt-20 relative overflow-hidden">
    <!-- Subtle gradient overlay -->
    <div class="absolute inset-0 bg-linear-to-b from-transparent via-transparent to-[#0b0b0b] pointer-events-none"></div>

    <!-- Ambient glow effect -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-white/2 rounded-full blur-3xl pointer-events-none"></div>

    <div class="max-w-6xl mx-auto text-center relative z-10">
      <!-- Main headline with gradient -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-tight mb-6">
        <span class="bg-linear-to-r from-white via-gray-200 to-gray-400 bg-clip-text text-transparent">
          Cinema-grade videography
        </span>
        <br />
        <span class="text-gray-300">for brands and creators.</span>
      </h1>

      <!-- Sub-headline -->
      <p class="text-lg sm:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        I help creators and businesses tell their story through high-quality video production and strategic content.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <!-- Primary CTA -->
        <a
          href="#portfolio"
          class="group relative px-8 py-4 bg-white text-black font-semibold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-[0_0_40px_rgba(255,255,255,0.15)]"
        >
          <span class="relative z-10">View My Work</span>
        </a>

        <!-- Secondary CTA -->
        <a
          href="https://youtube.com/@alphabravomedia"
          target="_blank"
          rel="noopener noreferrer"
          class="group px-8 py-4 border border-gray-700 text-gray-300 font-medium rounded-full transition-all duration-300 hover:border-gray-500 hover:text-white hover:bg-white/5"
        >
          <span class="flex items-center gap-2">
            <Icon name="simple-icons:youtube" class="w-5 h-5" />
            YouTube Channel
          </span>
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce">
      <Icon name="mdi:chevron-down" class="w-6 h-6 text-gray-600" />
    </div>
  </section>

  <!-- Featured Work / Showreel Section -->
  <section id="showreel" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-4">Featured Work</h2>
        <p class="text-gray-400 max-w-xl mx-auto">A selection of recent projects showcasing cinematic storytelling and high-end production value.</p>
      </div>

      <!-- YouTube Embed with glow effect -->
      <div class="relative group">
        <!-- Glow effect behind video -->
        <div class="absolute -inset-4 bg-linear-to-r from-purple-500/20 via-pink-500/20 to-orange-500/20 rounded-3xl blur-2xl opacity-50 group-hover:opacity-75 transition-opacity duration-500"></div>

        <!-- Video container -->
        <div class="relative rounded-2xl overflow-hidden shadow-2xl shadow-black/50">
          <YouTube
            id="dQw4w9WgXcQ"
            class="w-full aspect-video"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Latest from the Studio Section -->
  <section id="portfolio" class="py-24 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Section header -->
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-4">Latest from the Studio</h2>
        <p class="text-gray-400 max-w-xl mx-auto">Recent projects, tutorials, and behind-the-scenes content.</p>
      </div>

      <!-- Portfolio Grid -->
      <div class="mb-16">
        <h3 class="text-xl font-semibold text-gray-300 mb-6 flex items-center gap-3">
          <span class="w-8 h-px bg-gray-700"></span>
          Portfolio
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPortfolio.map((item) => (
            <a
              href={`${base}portfolio/${item.slug}`}
              class="group relative bg-gray-900/50 rounded-xl overflow-hidden border border-gray-800/50 transition-all duration-300 hover:scale-[1.02] hover:border-gray-700 hover:shadow-xl hover:shadow-black/20"
            >
              <!-- Thumbnail -->
              <div class="aspect-video bg-linear-to-br from-gray-800 to-gray-900 relative overflow-hidden">
                {(() => {
                  const imageUrl = item.data.image || (item.data.videoId ? `https://img.youtube.com/vi/${item.data.videoId}/maxresdefault.jpg` : null);
                  if (imageUrl) {
                    return (
                      <img 
                        src={imageUrl} 
                        alt={item.data.title} 
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    );
                  }
                })()}
                <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>
                <!-- Category badge -->
                <span class="absolute top-3 left-3 px-3 py-1 bg-white/10 backdrop-blur-sm rounded-full text-xs font-medium text-gray-300">
                  {item.data.category}
                </span>
                <!-- Play icon on hover if video -->
                {item.data.videoId && (
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-14 h-14 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                      <Icon name="mdi:play" class="w-6 h-6 text-white ml-1" />
                    </div>
                  </div>
                )}
              </div>
              <!-- Content -->
              <div class="p-5">
                <h4 class="text-lg font-semibold text-white mb-2 group-hover:text-gray-200 transition-colors">
                  {item.data.title}
                </h4>
                <p class="text-sm text-gray-500">
                  {item.data.clientName}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>

      <!-- Blog Grid -->
      <div>
        <h3 class="text-xl font-semibold text-gray-300 mb-6 flex items-center gap-3">
          <span class="w-8 h-px bg-gray-700"></span>
          Latest Blogs
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestBlog.map((post) => (
            <a
              href={`${base}blog/${post.slug}`}
              class="group relative bg-gray-900/50 rounded-xl overflow-hidden border border-gray-800/50 transition-all duration-300 hover:scale-[1.02] hover:border-gray-700 hover:shadow-xl hover:shadow-black/20"
            >
              <!-- Thumbnail with play button -->
              <div class="aspect-video bg-linear-to-br from-gray-800 to-gray-900 relative overflow-hidden flex items-center justify-center">
                {post.data.youtubeId && (
                  <img 
                    src={`https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`} 
                    alt={post.data.title} 
                    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  />
                )}
                <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>
                {post.data.youtubeId && (
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <div class="w-14 h-14 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                      <Icon name="mdi:play" class="w-6 h-6 text-white ml-1" />
                    </div>
                  </div>
                )}
              </div>
              <!-- Content -->
              <div class="p-5">
                <h4 class="text-lg font-semibold text-white mb-2 group-hover:text-gray-200 transition-colors">
                  {post.data.title}
                </h4>
                <p class="text-sm text-gray-500 line-clamp-2">
                  {post.data.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Line clamp for text truncation */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
