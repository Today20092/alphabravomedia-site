---
import BaseLayout from "../layouts/BaseLayout.astro";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";
import ServicesTeaser from "../components/ServicesTeaser.astro";
import GoogleReviewsBand from "../components/GoogleReviewsBand.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allBlogPosts = await getCollection("blog");
const allPortfolio = await getCollection("portfolio");

const latestBlog = allBlogPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const latestPortfolio = allPortfolio
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<BaseLayout>
  <section class="px-6 pb-12 pt-32 sm:pb-16 sm:pt-36">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,1.1fr)_minmax(0,0.9fr)] lg:items-end">
        <div class="site-page-header mb-0">
          <span class="site-kicker">Alpha Bravo Media</span>
          <h1 class="site-page-title max-w-3xl">
            Cinematic video production that helps brands earn trust, creators grow
            their audience, and events feel worth remembering.
          </h1>
          <p class="site-page-copy max-w-2xl text-base sm:text-lg">
            Strategy, filming, editing, and delivery from one production partner.
            Built for businesses that need polished content, and for viewers from
            YouTube who want to explore the blog, gear, and the way we work.
          </p>
          <p class="mt-4 max-w-2xl text-sm leading-6 text-[var(--site-text-soft)] sm:text-base">
            Hire us for production. Read the blog, explore gear, and learn how we
            build each project.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={`${base}#contact`} class="site-button-primary">
              Contact
            </a>
            <a href={`${base}blog`} class="site-button-secondary">
              Read the blog
            </a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
          <a href={`${base}services`} class="site-card site-card-interactive group p-6">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
                  For customers
                </p>
                <h2 class="mt-3 font-['Sora',sans-serif] text-xl font-semibold text-[var(--site-text)]">
                  Hire us for production
                </h2>
                <p class="mt-3 max-w-sm text-sm leading-6 text-[var(--site-text-muted)]">
                  Services, portfolio, and a direct path to start a project.
                </p>
              </div>
              <span class="site-chip shrink-0">Book</span>
            </div>
          </a>

          <a href={`${base}gear`} class="site-card site-card-interactive group p-6">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
                  From YouTube
                </p>
                <h2 class="mt-3 font-['Sora',sans-serif] text-xl font-semibold text-[var(--site-text)]">
                  Explore the blog and gear
                </h2>
                <p class="mt-3 max-w-sm text-sm leading-6 text-[var(--site-text-muted)]">
                  Gear notes, production insights, and the tools behind the work.
                </p>
              </div>
              <span class="site-chip shrink-0">Learn</span>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="about" class="px-6 pb-20 sm:pb-24">
    <div class="site-shell">
      <div class="grid gap-8 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-center">
        <div class="max-w-2xl">
          <span class="site-kicker">About</span>
          <h2 class="site-section-title mt-4">
            Production built to clarify the message and raise the standard.
          </h2>
          <p class="site-section-copy mt-4">
            Planning, filming, editing, and delivery are handled together so every
            project feels intentional, not assembled.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <span class="site-stat">Videography</span>
            <span class="site-stat">A/V production</span>
            <span class="site-stat">Content strategy</span>
          </div>
        </div>

        <div class="site-card">
          <div class="site-card-media aspect-video">
            <YouTube id="wXsf-nbHbzU" class="m-0 w-full max-w-full aspect-video" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <ServicesTeaser />
  <GoogleReviewsBand />

  <section class="px-6 pb-12 sm:pb-16">
    <div class="site-shell">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div class="site-page-header mb-0">
          <span class="site-kicker">Selected Work</span>
          <h2 class="site-section-title">Recent projects that show the standard.</h2>
        </div>
        <a href={`${base}portfolio`} class="site-button-secondary hidden sm:inline-flex">
          Browse selected work
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {latestPortfolio.map((item) => (
          <a
            href={`${base}portfolio/${item.slug}`}
            class="site-card site-card-interactive group"
          >
            <div class="site-card-media">
              {(() => {
                const thumbImage = item.data.image;
                const youtubeUrl = item.data.videoId
                  ? `https://img.youtube.com/vi/${item.data.videoId}/maxresdefault.jpg`
                  : null;

                if (thumbImage) {
                  return (
                    <Image
                      src={thumbImage}
                      alt={item.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                if (youtubeUrl) {
                  return (
                    <img
                      src={youtubeUrl}
                      alt={item.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                return (
                  <div class="flex h-full items-center justify-center text-[var(--site-text-soft)]">
                    <Icon name="mdi:image-outline" class="h-10 w-10" />
                  </div>
                );
              })()}
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/70 to-transparent"></div>
              <span class="site-chip absolute left-4 top-4">{item.data.category}</span>
            </div>
            <div class="site-card-body">
              <h3 class="site-card-title">{item.data.title}</h3>
              <div class="site-meta-row">
                <span>{item.data.clientName}</span>
                <span>See project</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <a href={`${base}portfolio`} class="site-button-secondary mt-6 sm:hidden">
        Browse selected work
      </a>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="site-shell">
      <div class="mb-8 flex items-end justify-between gap-4">
        <div class="site-page-header mb-0">
          <span class="site-kicker">Insights</span>
          <h2 class="site-section-title">Practical lessons from real production work.</h2>
        </div>
        <a href={`${base}blog`} class="site-button-secondary hidden sm:inline-flex">
          Read insights
        </a>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {latestBlog.map((post) => (
          <a href={`${base}blog/${post.slug}`} class="site-card site-card-interactive group">
            <div class="site-card-media">
              {(() => {
                const thumbImage = post.data.image;
                const youtubeUrl = post.data.youtubeId
                  ? `https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`
                  : null;

                if (thumbImage) {
                  return (
                    <Image
                      src={thumbImage}
                      alt={post.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                if (youtubeUrl) {
                  return (
                    <img
                      src={youtubeUrl}
                      alt={post.data.title}
                      class="absolute inset-0 h-full w-full object-cover"
                    />
                  );
                }

                return (
                  <div class="flex h-full items-center justify-center text-[var(--site-text-soft)]">
                    <Icon name="mdi:book-open-page-variant-outline" class="h-10 w-10" />
                  </div>
                );
              })()}
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/70 to-transparent"></div>
            </div>
            <div class="site-card-body">
              <div class="site-meta-row">
                <time>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
              <h3 class="site-card-title line-clamp-2">{post.data.title}</h3>
              <p class="site-card-copy line-clamp-2">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      <a href={`${base}blog`} class="site-button-secondary mt-6 sm:hidden">
        Read insights
      </a>
    </div>
  </section>
</BaseLayout>
