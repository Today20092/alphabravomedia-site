---
import { getEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

// Fetch the Terms of Service content
const termsEntry = await getEntry("legal", "terms");
const { Content } = termsEntry ? await termsEntry.render() : { Content: null };

export const prerender = true;
---

<BaseLayout
  title={(termsEntry?.data?.title as string) ||
    "Terms of Service | Alpha Bravo Media"}
>
  <section class="pt-32 pb-24 px-6 min-h-screen">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <h1
          class="text-4xl sm:text-5xl font-bold tracking-tight text-white mb-4 font-['Sora',sans-serif]"
        >
          {termsEntry?.data?.title || "Terms of Service & Booking Agreement"}
        </h1>
        <p class="text-lg text-[#a8998a]">
          Please review our policies and procedures before booking your session.
        </p>
      </div>

      <div
        class="bg-[#141211]/60 backdrop-blur-md border border-[#2a2520] rounded-2xl p-6 sm:p-8 mb-16 shadow-xl shadow-black/20"
      >
        <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
          <svg
            class="w-6 h-6 text-[#c8875c]"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path></svg
          >
          The Quick Summary (TL;DR)
        </h2>
        <ul class="space-y-3">
          <li class="flex items-start gap-3 text-[#a8998a]">
            <svg
              class="w-5 h-5 text-[#7a6f63] mt-0.5 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span
              >A <strong class="text-white font-semibold"
                >25% non-refundable retainer</strong
              > is required to secure your booking date.</span
            >
          </li>
          <li class="flex items-start gap-3 text-[#a8998a]">
            <svg
              class="w-5 h-5 text-[#7a6f63] mt-0.5 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span
              >We offer up to <strong class="text-white font-semibold"
                >3 rounds of revisions</strong
              > for shorter videos (under 6-7 minutes) and <strong
                class="text-white font-semibold">2 rounds</strong
              > for longer-form content.</span
            >
          </li>
          <li class="flex items-start gap-3 text-[#a8998a]">
            <svg
              class="w-5 h-5 text-[#7a6f63] mt-0.5 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span
              >We require at least <strong class="text-white font-semibold"
                >14 days' notice</strong
              > for rescheduling or cancellations.</span
            >
          </li>
          <li class="flex items-start gap-3 text-[#a8998a]">
            <svg
              class="w-5 h-5 text-[#7a6f63] mt-0.5 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span
              >Currently, we offer videography exclusively for the <strong
                class="text-white font-semibold flex-col"
                >men's section and general unsegregated events</strong
              >.</span
            >
          </li>
          <li class="flex items-start gap-3 text-[#a8998a]">
            <svg
              class="w-5 h-5 text-[#7a6f63] mt-0.5 shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M5 13l4 4L19 7"></path></svg
            >
            <span
              >Raw footage is available for an additional fee, provided you
              supply an adequate physical hard drive.</span
            >
          </li>
        </ul>
      </div>

      {
        Content ? (
          <article
            class="prose prose-invert max-w-none
          prose-h2:text-2xl prose-h2:font-semibold prose-h2:text-white prose-h2:mb-4 prose-h2:tracking-tight prose-h2:border-b prose-h2:border-[#2a2520] prose-h2:pb-2 prose-h2:mt-12 prose-h2:font-['Sora',sans-serif]
          prose-p:text-[#a8998a] prose-p:leading-relaxed prose-p:mb-4
          prose-strong:text-[#f5e6d3]
          prose-ul:list-disc prose-ul:pl-5 prose-ul:space-y-2 prose-ul:marker:text-[#7a6f63] prose-ul:mb-4
          prose-li:text-[#a8998a]
        "
          >
            <Content />
          </article>
        ) : (
          <div class="text-center text-[#a8998a] py-12">
            Unable to load terms of service content.
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
