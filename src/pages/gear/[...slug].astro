---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

export async function getStaticPaths() {
  const gear = await getCollection("gear");
  return gear.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

// Get related items (same category, excluding current)
const allGear = await getCollection("gear");
const relatedItems = allGear
  .filter((g) => g.slug !== item.slug && g.data.category === item.data.category)
  .slice(0, 3);
---

<BaseLayout title={`${item.data.title} | Alpha Bravo Media`}>
  <article data-pagefind-body class="pt-32 pb-24 px-6">
    <span data-pagefind-meta="type" class="sr-only">Gear</span>
    <span data-pagefind-meta="category" style="display:none"
      >{item.data.category}</span
    >
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a
        href={`${base}gear`}
        class="inline-flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors mb-8"
      >
        <Icon name="mdi:arrow-left" class="w-4 h-4" />
        Back to Gear
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Image -->
        <div
          class="aspect-square bg-linear-to-br from-gray-800 to-gray-900 rounded-2xl overflow-hidden"
        >
          <img
            src={item.data.imageUrl}
            alt={item.data.title}
            class="w-full h-full object-contain"
          />
        </div>

        <!-- Details -->
        <div>
          <span
            class="inline-block px-3 py-1 bg-[#7c956b]/10 rounded-full text-xs font-medium text-[#7c956b] mb-4"
          >
            {item.data.category}
          </span>
          <h1
            class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-6 font-['Sora',sans-serif]"
          >
            {item.data.title}
          </h1>

          <!-- Amazon Button -->
          <a
            href={item.data.amazonLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-[#232F3E] hover:bg-[#131921] text-white font-semibold rounded-full transition-colors mb-8"
          >
            <Icon name="simple-icons:amazon" class="w-5 h-5 shrink-0" />
            View on Amazon
          </a>

          <p data-pagefind-ignore class="text-sm text-[#7a6f63] mb-8">
            Affiliate link - I earn a commission on purchases
          </p>

          <!-- Content -->
          <div class="prose prose-invert max-w-none">
            <Content />
          </div>
        </div>
      </div>

      <!-- Related Gear -->
      {
        relatedItems.length > 0 && (
          <div
            data-pagefind-ignore
            class="border-t border-[#2a2520] pt-12 mt-16"
          >
            <h2 class="text-2xl font-bold text-white mb-8 font-['Sora',sans-serif]">
              More {item.data.category} Gear
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
              {relatedItems.map((related) => (
                <a
                  href={`${base}gear/${related.slug}`}
                  class="group relative bg-[#141211] rounded-xl overflow-hidden border border-[#2a2520] transition-all duration-300 hover:scale-[1.02] hover:border-[#c8875c]/30"
                >
                  <div class="aspect-square bg-linear-to-br from-gray-800 to-gray-900 flex items-center justify-center overflow-hidden">
                    {related.data.imageUrl ? (
                      <img
                        src={related.data.imageUrl}
                        alt={related.data.title}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <Icon name="mdi:camera" class="w-12 h-12 text-gray-700" />
                    )}
                  </div>
                  <div class="p-4">
                    <h3 class="text-sm font-semibold text-white group-hover:text-gray-200 transition-colors">
                      {related.data.title}
                    </h3>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </article>
</BaseLayout>
