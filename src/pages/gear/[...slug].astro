---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const gear = await getCollection('gear');
  return gear.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();

const base = import.meta.env.BASE_URL;

// Get related items (same category, excluding current)
const allGear = await getCollection('gear');
const relatedItems = allGear
  .filter(g => g.slug !== item.slug && g.data.category === item.data.category)
  .slice(0, 3);
---

<BaseLayout title={`${item.data.title} | Alpha Bravo Media`}>
  <article class="pt-32 pb-24 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Back link -->
      <a href={`${base}gear`} class="inline-flex items-center gap-2 text-gray-400 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Gear
      </a>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Image -->
        <div class="aspect-square bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl flex items-center justify-center">
          <svg class="w-24 h-24 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>

        <!-- Details -->
        <div>
          <span class="inline-block px-3 py-1 bg-white/10 rounded-full text-xs font-medium text-gray-300 mb-4">
            {item.data.category}
          </span>
          <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-white mb-6">
            {item.data.title}
          </h1>

          <!-- Amazon Button -->
          <a
            href={item.data.amazonLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-[#FF9900] hover:bg-[#FFa31a] text-black font-semibold rounded-full transition-colors mb-8"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.958 10.09c0 1.232.029 2.256-.591 3.351-.502.891-1.301 1.438-2.186 1.438-1.214 0-1.922-.924-1.922-2.292 0-2.692 2.415-3.182 4.7-3.182v.685zm3.186 7.705c-.209.189-.512.201-.745.074-1.052-.872-1.238-1.276-1.814-2.106-1.734 1.767-2.962 2.297-5.209 2.297-2.66 0-4.731-1.641-4.731-4.925 0-2.565 1.391-4.309 3.37-5.164 1.715-.754 4.11-.891 5.942-1.095v-.41c0-.753.06-1.642-.383-2.294-.385-.579-1.124-.82-1.775-.82-1.205 0-2.277.618-2.54 1.897-.054.285-.261.567-.549.582l-3.061-.333c-.259-.056-.548-.266-.472-.66.704-3.716 4.06-4.838 7.066-4.838 1.537 0 3.547.41 4.758 1.574 1.538 1.436 1.392 3.352 1.392 5.438v4.923c0 1.481.616 2.13 1.192 2.929.204.287.249.63-.01.839l-2.431 2.091z"/>
            </svg>
            View on Amazon
          </a>

          <p class="text-sm text-gray-500 mb-8">Affiliate link - I earn a commission on purchases</p>

          <!-- Content -->
          <div class="prose prose-invert max-w-none">
            <Content />
          </div>
        </div>
      </div>

      <!-- Related Gear -->
      {relatedItems.length > 0 && (
        <div class="border-t border-gray-800 pt-12 mt-16">
          <h2 class="text-2xl font-bold text-white mb-8">More {item.data.category} Gear</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {relatedItems.map((related) => (
              <a
                href={`${base}gear/${related.slug}`}
                class="group relative bg-gray-900/50 rounded-xl overflow-hidden border border-gray-800/50 transition-all duration-300 hover:scale-[1.02] hover:border-gray-700"
              >
                <div class="aspect-square bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center">
                  <svg class="w-12 h-12 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                  </svg>
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-semibold text-white group-hover:text-gray-200 transition-colors">
                    {related.data.title}
                  </h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
