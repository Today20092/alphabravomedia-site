---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../site-config";

export async function getStaticPaths() {
  const gear = await getCollection("gear");
  return gear.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allGear = await getCollection("gear");
const relatedItems = allGear
  .filter((g) => g.id !== item.id && g.data.category === item.data.category)
  .slice(0, 3);
const gearDescription = item.data.specs
  ? `${item.data.title}: ${item.data.specs}`
  : `${item.data.title} is part of the working ${item.data.category.toLowerCase()} kit used by Alpha Bravo Media for client and creator productions.`;
---

<BaseLayout
  title={`${item.data.title} | Gear Review | Alpha Bravo Media`}
  description={gearDescription}
  ogImage={item.data.imageUrl}
  ogImageAlt={item.data.title}
  ogType="article"
  author={siteConfig.founderName}
>
  <article
    data-pagefind-body
    class="site-section-hero"
    itemScope
    itemType="https://schema.org/Review"
  >
    <span data-pagefind-meta="type" class="sr-only">Gear</span>
    <span data-pagefind-meta="category" style="display:none">{item.data.category}</span>

    <div class="site-shell">
      <a href={`${base}gear`} class="site-link inline-flex items-center gap-2 text-sm">
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        Back to Gear
      </a>

      <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
        <div class="site-card">
          <div class="site-card-media aspect-square flex items-center justify-center p-8">
            <img
              src={item.data.imageUrl}
              alt={item.data.title}
              width="1500"
              height="1500"
              class="h-full w-full object-contain"
            />
          </div>
        </div>

        <div>
          <div class="site-page-header">
            <span class="site-chip site-chip-muted">{item.data.category}</span>
            <h1 itemProp="headline" class="site-page-title max-w-3xl">{item.data.title}</h1>
            <div class="site-meta-row">
              <span>{item.data.category}</span>
              <a href={`${base}about`} rel="author" itemProp="author" class="site-link">
                Recommended by {siteConfig.founderName}
              </a>
            </div>
          </div>

          <div class="flex flex-wrap gap-3">
            <a
              href={item.data.amazonLink}
              target="_blank"
              rel="noopener noreferrer"
              class="site-button-primary"
            >
              <Icon name="simple-icons:amazon" class="h-4 w-4" />
              View on Amazon
            </a>
            <span class="site-chip site-chip-muted">
              Affiliate link
            </span>
          </div>

          <div
            class="site-prose prose prose-a:text-site-accent-strong mt-8 max-w-none prose-headings:text-balance prose-h1:text-3xl md:prose-h1:text-4xl prose-h2:text-2xl md:prose-h2:text-3xl prose-h3:text-xl md:prose-h3:text-2xl"
          >
            <Content />
          </div>
        </div>
      </div>

      {relatedItems.length > 0 && (
        <section data-pagefind-ignore class="mt-16 border-t border-site-border pt-12">
          <div class="mb-8">
            <span class="site-kicker">Related</span>
            <h2 class="site-section-title mt-4">More {item.data.category} gear</h2>
          </div>
          <div class="grid gap-6 md:grid-cols-3">
            {relatedItems.map((related) => (
              <a
                href={`${base}gear/${related.id}`}
                class="site-card site-card-interactive group"
              >
                <div class="site-card-media aspect-square flex items-center justify-center p-5">
                  {related.data.imageUrl ? (
                    <img
                      src={related.data.imageUrl}
                      alt={related.data.title}
                      width="1500"
                      height="1500"
                      class="h-full w-full object-contain"
                    />
                  ) : (
                    <Icon name="mdi:camera-outline" class="h-12 w-12 text-site-text-soft" />
                  )}
                </div>
                <div class="site-card-body">
                  <h3 class="site-card-title text-base">{related.data.title}</h3>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </article>
</BaseLayout>
