---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog | Alpha Bravo Media">
  <section class="px-6 pb-24 pt-32">
    <div class="site-shell">
      <div class="site-page-header">
        <span class="site-kicker">Blog</span>
        <h1 class="site-page-title">Tutorials, reviews, and studio notes from the work.</h1>
        <p class="site-page-copy text-lg">
          Practical posts for creators and businesses building better video systems,
          better marketing assets, and better production habits.
        </p>
      </div>

      <div class="site-panel mb-12 p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div>
            <span class="site-kicker">Creator Community</span>
            <h2 class="site-section-title mt-4">
              Learn video, marketing, and AI with other creators.
            </h2>
            <p class="site-section-copy mt-4">
              Join the Discord for practical workflows, creator-business conversations,
              and real examples of how people are shipping the work.
            </p>
          </div>
          <a
            href="https://discord.gg/5C8yFbzv77"
            target="_blank"
            rel="noopener noreferrer"
            class="site-button-primary"
          >
            <Icon name="simple-icons:discord" class="h-4 w-4" />
            Join the Discord
          </a>
        </div>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((post) => (
          <a href={`${base}blog/${post.slug}`} class="site-card site-card-interactive group">
            <div class="site-card-media">
              {post.data.image ? (
                <Image
                  src={post.data.image}
                  alt={post.data.title}
                  class="absolute inset-0 h-full w-full object-cover"
                />
              ) : (
                <div class="flex h-full items-center justify-center text-[var(--site-text-soft)]">
                  <Icon name="mdi:book-open-page-variant-outline" class="h-10 w-10" />
                </div>
              )}
              {post.data.youtubeId && (
                <div class="absolute left-4 top-4 rounded-full border border-[var(--site-border)] bg-black/40 px-3 py-1 text-xs font-medium text-[var(--site-text)]">
                  Video
                </div>
              )}
              <div class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/70 to-transparent"></div>
            </div>

            <div class="site-card-body">
              <div class="site-meta-row">
                <time>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </div>
              <h2 class="site-card-title line-clamp-2">{post.data.title}</h2>
              <p class="site-card-copy line-clamp-2">{post.data.description}</p>
            </div>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="site-panel-muted mt-10 px-6 py-16 text-center">
          <p class="text-lg text-[var(--site-text)]">No posts yet.</p>
          <p class="mt-3 text-sm text-[var(--site-text-soft)]">Check back soon.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
