---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { YouTube } from "@astro-community/astro-embed-youtube";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../site-config";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
const articleOgImage = post.data.image?.src ??
  (post.data.youtubeId
    ? `https://img.youtube.com/vi/${post.data.youtubeId}/maxresdefault.jpg`
    : "/alpha-bravo-logo.svg");
---

<BaseLayout
  title={`${post.data.title} | Alpha Bravo Media`}
  description={post.data.description}
  ogImage={articleOgImage}
  ogImageAlt={post.data.title}
  ogType="article"
  author={siteConfig.founderName}
  publishedTime={post.data.pubDate.toISOString()}
>
  <article
    data-pagefind-body
    class="site-section-hero"
    itemscope
    itemtype="https://schema.org/Article"
  >
    <span data-pagefind-meta="type" class="sr-only">Blog Post</span>

    <div class="site-shell">
      <a href={`${base}blog`} class="site-link inline-flex items-center gap-2 text-sm">
        <Icon name="mdi:arrow-left" class="h-4 w-4" />
        Back to Blog
      </a>

      <header class="site-page-header mt-8">
        <div class="site-meta-row">
          <time itemprop="datePublished" datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          <a href={`${base}about`} rel="author" itemprop="author" class="site-link">
            By {siteConfig.founderName}
          </a>
        </div>
        <h1 itemprop="headline" class="site-page-title max-w-4xl">{post.data.title}</h1>
        <p itemprop="description" class="site-page-copy text-lg">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {post.data.tags.map((tag: string) => (
              <span class="site-chip site-chip-muted">{tag}</span>
            ))}
          </div>
        )}
      </header>

      {post.data.youtubeId && (
        <div class="site-card mb-12 overflow-hidden">
          <div class="site-card-media aspect-video">
            <YouTube
              id={post.data.youtubeId}
              class="m-0 w-full aspect-video"
              poster="maxresdefault"
            />
          </div>
        </div>
      )}

      <div
        class="site-prose prose prose-a:text-site-accent-strong md:prose-lg max-w-none prose-headings:text-balance prose-h1:text-3xl md:prose-h1:text-4xl prose-h2:text-2xl md:prose-h2:text-3xl prose-h3:text-xl md:prose-h3:text-2xl"
      >
        <Content />
      </div>

      <aside class="site-panel mt-16 p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div>
            <span class="site-kicker">Creator Community</span>
            <h2 class="site-section-title mt-4">
              Want more help with video, marketing, and AI workflows?
            </h2>
            <p class="site-section-copy mt-4">
              Join the Discord to learn with other creators, ask questions, and compare
              how people are using these tools in real businesses.
            </p>
          </div>
          <a
            href="https://discord.gg/5C8yFbzv77"
            target="_blank"
            rel="noopener noreferrer"
            class="site-button-primary"
          >
            <Icon name="simple-icons:discord" class="h-4 w-4" />
            Join the Discord
          </a>
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>
