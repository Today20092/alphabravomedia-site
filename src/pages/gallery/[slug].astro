---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryGate from "../../components/GalleryGate.astro";

export async function getStaticPaths() {
  const entries = await getCollection("galleries");
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, date, description, galleryLayout, password, remoteBase } = entry.data;
const { Content } = await render(entry);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const slug = entry.slug;

const allImageLists = import.meta.glob<{ default: string[] }>(
  "/src/content/galleries/**/images.json",
  { eager: true },
);

const remoteJsonKey = Object.keys(allImageLists).find((k) =>
  k.includes(`/galleries/${slug}/images.json`),
);
const remoteFilenames: string[] = remoteJsonKey
  ? ((allImageLists[remoteJsonKey].default ??
      allImageLists[remoteJsonKey]) as unknown as string[])
  : [];

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/content/galleries/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}",
  { eager: true },
);

const allOriginalsUrl = import.meta.glob<string>(
  "/src/content/galleries/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}",
  { eager: true, query: "?url", import: "default" },
);

const galleryImages =
  remoteBase && remoteFilenames.length > 0
    ? remoteFilenames.map((filename, i) => ({
        src: `${remoteBase}/${filename}` as string,
        alt: `${title} — photo ${i + 1}`,
        fullSrc: `${remoteBase}/${filename}`,
      }))
    : Object.entries(allImages)
        .filter(([path]) => path.includes(`/galleries/${slug}/`))
        .sort(([a], [b]) => a.localeCompare(b))
        .map(([path, mod], i) => ({
          src: mod.default as unknown as string,
          alt: `${title} — photo ${i + 1}`,
          fullSrc: allOriginalsUrl[path] ?? "",
        }));

const formattedDate = new Date(date + "T00:00:00").toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${title} | Photo Gallery | Alpha Bravo Media`}
  ogImage={password ? `https://alphabravomedia.co/alpha-bravo-logo.svg` : undefined}
  noIndex={!!password}
>
  <section class="min-h-screen px-4 pb-24 pt-32 sm:px-6">
    <div class="site-shell">
      <a href={`${base}gallery`} class="site-link inline-flex items-center gap-2 text-sm">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        All Galleries
      </a>

      <div class="site-page-header mt-8">
        <div class="site-meta-row">
          <span>{formattedDate}</span>
          <span>{galleryImages.length} photo{galleryImages.length !== 1 ? "s" : ""}</span>
        </div>
        <h1 class="site-page-title max-w-4xl">{title}</h1>
        {description && <p class="site-page-copy text-lg">{description}</p>}
      </div>

      <div class="site-prose prose prose-invert prose-sm mb-10 max-w-2xl">
        <Content />
      </div>

      <GalleryGate
        images={galleryImages}
        layout={galleryLayout}
        passwordHash={password}
        slug={slug}
      />
    </div>
  </section>
</BaseLayout>
