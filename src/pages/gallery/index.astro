---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const entries = await getCollection("galleries");
const sorted = entries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

const allImages = import.meta.glob<{ default: ImageMetadata }>(
  "/src/content/galleries/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}",
  { eager: true },
);

const allImageLists = import.meta.glob<{ default: string[] }>(
  "/src/content/galleries/**/images.json",
  { eager: true },
);

function getImagesForSlug(slug: string) {
  return Object.entries(allImages)
    .filter(([path]) => path.includes(`/galleries/${slug}/`))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([_, mod]) => mod.default);
}

function getRemoteFilenames(slug: string): string[] {
  const key = Object.keys(allImageLists).find((k) =>
    k.includes(`/galleries/${slug}/images.json`),
  );
  if (!key) return [];
  const val = allImageLists[key];
  return (val.default ?? val) as string[];
}
---

<BaseLayout title="Photo Gallery | Alpha Bravo Media">
  <section class="site-section-hero min-h-screen">
    <div class="site-shell">
      <div class="site-page-header">
        <span class="site-kicker">Gallery</span>
        <h1 class="site-page-title">Photo galleries, ready to browse and download.</h1>
        <p class="site-page-copy text-lg">
          Event galleries are organized by shoot and date, with private galleries staying
          protected behind their access gate.
        </p>
      </div>

      {sorted.length === 0 ? (
        <div class="site-panel-muted px-6 py-24 text-center text-site-text-soft">
          <p class="text-lg text-site-text">No galleries yet.</p>
          <p class="mt-3 text-sm">Check back soon.</p>
        </div>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {sorted.map((entry) => {
            const isRemote = !!entry.data.remoteBase;
            const isPrivate = !!entry.data.password;
            const remoteFiles = isRemote ? getRemoteFilenames(entry.slug) : [];
            const localImgs = isRemote ? [] : getImagesForSlug(entry.slug);
            const count = isRemote ? remoteFiles.length : localImgs.length;
            const remoteCoverUrl =
              isRemote && remoteFiles.length > 0
                ? `${entry.data.remoteBase}/${remoteFiles[0]}`
                : null;
            const localCover = localImgs[0];

            return (
              <a
                href={`${base}gallery/${entry.slug}`}
                class="site-card site-card-interactive group"
              >
                <div class="site-card-media aspect-[4/3]">
                  {remoteCoverUrl && isPrivate ? (
                    <img
                      src={remoteCoverUrl}
                      alt=""
                      aria-hidden="true"
                      class="h-full w-full object-cover scale-110"
                      style="filter: blur(28px);"
                    />
                  ) : remoteCoverUrl ? (
                    <img
                      src={remoteCoverUrl}
                      alt={entry.data.title}
                      loading="lazy"
                      decoding="async"
                      class="h-full w-full object-cover"
                    />
                  ) : localCover ? (
                    <Image
                      src={localCover}
                      alt={entry.data.title}
                      class="h-full w-full object-cover"
                    />
                  ) : (
                    <div class="flex h-full items-center justify-center text-site-text-soft">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                  )}
                  <span class="site-chip site-chip-muted absolute bottom-4 right-4">
                    {count} photo{count !== 1 ? "s" : ""}
                  </span>
                </div>
                <div class="site-card-body">
                  <h2 class="site-card-title">{entry.data.title}</h2>
                  <div class="site-meta-row">
                    <span>
                      {new Date(entry.data.date + "T00:00:00").toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </span>
                  </div>
                  {entry.data.description && (
                    <p class="site-card-copy line-clamp-2">{entry.data.description}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
