---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const entries = await getCollection("galleries");
const sorted = entries.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Auto-discover all gallery images (local)
const allImages = import.meta.glob<{ default: ImageMetadata }>(
  '/src/content/galleries/**/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);

// Auto-discover remote image lists (R2 galleries)
const allImageLists = import.meta.glob<{ default: string[] }>(
  '/src/content/galleries/**/images.json',
  { eager: true }
);

// Build a map of slug -> [sorted image modules]
function getImagesForSlug(slug: string) {
  return Object.entries(allImages)
    .filter(([path]) => path.includes(`/galleries/${slug}/`))
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([_, mod]) => mod.default);
}

function getRemoteFilenames(slug: string): string[] {
  const key = Object.keys(allImageLists).find(k => k.includes(`/galleries/${slug}/images.json`));
  if (!key) return [];
  const val = allImageLists[key];
  return (val.default ?? val) as string[];
}
---

<BaseLayout title="Photo Gallery | Alpha Bravo Media">
  <div class="min-h-screen pt-28 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-white font-['Sora',sans-serif] mb-3">
          Photo Gallery
        </h1>
        <p class="text-[#a8998a] text-lg">Browse and download event photos</p>
      </div>

      {sorted.length === 0 ? (
        <div class="text-center py-24 text-[#7a6f63]">
          <p class="text-lg">No galleries yet — check back soon.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {sorted.map((entry) => {
            const isRemote = !!entry.data.remoteBase;
            const isPrivate = !!entry.data.password;
            const remoteFiles = isRemote ? getRemoteFilenames(entry.slug) : [];
            const localImgs = isRemote ? [] : getImagesForSlug(entry.slug);
            const count = isRemote ? remoteFiles.length : localImgs.length;
            const remoteCoverUrl = isRemote && remoteFiles.length > 0
              ? `${entry.data.remoteBase}/${remoteFiles[0]}`
              : null;
            const localCover = localImgs[0];
            return (
              <a
                href={`${base}gallery/${entry.slug}`}
                class="group block rounded-2xl overflow-hidden bg-[#141211] border border-[#2a2520] hover:border-[#4a3f35] transition-colors duration-300"
              >
                <!-- Cover image -->
                <div class="aspect-[4/3] overflow-hidden relative">
                  {remoteCoverUrl && isPrivate ? (
                    <img
                      src={remoteCoverUrl}
                      alt=""
                      aria-hidden="true"
                      class="w-full h-full object-cover scale-110"
                      style="filter: blur(28px);"
                    />
                  ) : remoteCoverUrl ? (
                    <img
                      src={remoteCoverUrl}
                      alt={entry.data.title}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : localCover ? (
                    <Image
                      src={localCover}
                      alt={entry.data.title}
                      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  ) : (
                    <div class="w-full h-full bg-[#1e1a17] flex items-center justify-center text-[#4a3f35]">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    </div>
                  )}
                  <!-- Photo count badge -->
                  <div class="absolute bottom-3 right-3 bg-black/70 backdrop-blur-sm text-white text-xs font-medium px-2.5 py-1 rounded-full">
                    {count} photo{count !== 1 ? "s" : ""}
                  </div>
                </div>
                <!-- Info -->
                <div class="p-5">
                  <h2 class="text-white font-semibold font-['Sora',sans-serif] text-lg leading-tight mb-1 group-hover:text-[#c8875c] transition-colors">
                    {entry.data.title}
                  </h2>
                  <p class="text-[#7a6f63] text-sm">
                    {new Date(entry.data.date + "T00:00:00").toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                  {entry.data.description && (
                    <p class="text-[#a8998a] text-sm mt-2 line-clamp-2">{entry.data.description}</p>
                  )}
                </div>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
