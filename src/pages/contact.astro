---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../site-config";

const inquiryPoints = [
  "What kind of project this is: brand video, podcast, event, editing, or A/V support.",
  "When you need it: date, location, and how urgent the timeline is.",
  "What success looks like: deliverables, usage, and budget range if you have one.",
];
---

<BaseLayout
  title={`Contact Alpha Bravo Media | Tampa Video Production`}
  description="Contact Alpha Bravo Media about brand video, podcast production, event coverage, editing, or A/V support in Tampa."
>
  <section class="site-section-hero">
    <div class="site-shell">
      <div class="site-page-header mb-0 max-w-3xl">
        <span class="site-kicker">Contact</span>
        <h1 class="site-page-title">
          Tell us what you need and we will handle the next step.
        </h1>
        <p class="site-page-copy mb-8 max-w-2xl sm:mb-10">
          Reach out about brand video, podcast production, events, editing, or A/V support.
          Email, call, or text if you want to talk through the project first.
        </p>
      </div>
    </div>
  </section>

  <section class="site-section">
    <div class="site-shell">
      <div class="space-y-14">
        <div class="site-panel p-6 sm:p-8 lg:p-10">
          <div class="grid gap-10 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.85fr)] lg:items-end">
            <div class="max-w-3xl">
              <span class="site-kicker">Direct contact</span>
              <h2 class="site-section-title mt-4">Use email, call, or text for now.</h2>
              <p class="site-section-copy mt-4 max-w-2xl">
                Reach out directly and we will handle scope, timing, and next steps from there.
              </p>
              <div class="mt-8">
                <div class="flex flex-col gap-3 sm:flex-row">
                  <a href={`mailto:${siteConfig.email}`} class="site-button-primary">
                    Email Ayoub
                  </a>
                  <a href={`tel:${siteConfig.phoneRaw}`} class="site-button-secondary">
                    Call Ayoub
                  </a>
                </div>
                <p class="site-link mt-4 inline-flex text-sm font-medium">
                  Text support is available after the first reply if that is easier.
                </p>
              </div>
            </div>

            <div class="border-t border-site-border-strong pt-6 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
              <p class="site-kicker">Response time</p>
              <p class="mt-4 max-w-sm text-sm leading-7 text-site-text-muted sm:text-base">
                Most inquiries get a reply within one business day. If the project is time-sensitive, call
                or text and include the date.
              </p>
            </div>
          </div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
          <div class="max-w-xl">
            <span class="site-kicker">What to include</span>
            <h2 class="site-section-title mt-4">Enough detail to estimate cleanly.</h2>
            <p class="site-section-copy mt-4 max-w-lg">
              Keep it simple. A short note with the basics is enough to move the conversation forward.
            </p>
          </div>

          <ul class="space-y-5 border-l border-site-border pl-6 text-sm leading-7 text-site-text-muted sm:pl-8 sm:text-base">
              {inquiryPoints.map((point) => (
                <li class="flex items-start gap-3">
                  <Icon name="mdi:check-circle" class="mt-0.5 h-5 w-5 shrink-0 text-site-accent" />
                  <span>{point}</span>
                </li>
              ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
