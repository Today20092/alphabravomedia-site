---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../site-config";

const inquiryPoints = [
  "What kind of project this is: brand video, podcast, event, editing, or A/V support.",
  "When you need it: date, location, and how urgent the timeline is.",
  "What success looks like: deliverables, usage, and budget range if you have one.",
];
---

<BaseLayout title={`Contact | ${siteConfig.siteName}`}>
  <section class="px-4 pt-32 sm:px-6 sm:pt-36">
    <div class="site-shell">
      <div class="site-page-header mb-0 max-w-3xl">
        <span class="site-kicker">Contact</span>
        <h1 class="site-page-title">
          Tell us what you need and we will handle the next step.
        </h1>
        <p class="site-page-copy mb-8 max-w-2xl sm:mb-10">
          Use the form for production inquiries, event questions, podcast support, editing, or A/V work.
          If you prefer to talk first, use the direct contact links below.
        </p>
      </div>
    </div>
  </section>

  <section class="px-4 pb-24 sm:px-6 sm:pb-28">
    <div class="site-shell">
      <div class="space-y-14">
        <div class="overflow-hidden rounded-[1.9rem] border border-[var(--site-border-strong)] bg-[linear-gradient(180deg,var(--site-card-media-tint),transparent)] p-6 shadow-[var(--site-shadow-sm)] sm:p-8 lg:p-10">
          <div class="grid gap-10 lg:grid-cols-[minmax(0,1.35fr)_minmax(18rem,0.85fr)] lg:items-end">
            <div class="max-w-3xl">
              <span class="site-kicker">Direct contact</span>
              <h2 class="site-section-title mt-4">Use email or phone for now.</h2>
              <p class="site-section-copy mt-4 max-w-2xl">
                The form is being reworked. Reach out directly and we will handle scope, timing, and next
                steps from there.
              </p>
              <div class="mt-8 flex flex-col gap-3 sm:flex-row">
                <a href={`mailto:${siteConfig.email}`} class="site-button-primary">
                  Email Ayoub
                </a>
                <a href={`tel:${siteConfig.phoneRaw}`} class="site-button-secondary">
                  Call Ayoub
                </a>
              </div>
            </div>

            <div class="border-t border-[var(--site-border-strong)] pt-6 lg:border-l lg:border-t-0 lg:pl-8 lg:pt-0">
              <p class="site-kicker">Response time</p>
              <p class="mt-4 max-w-sm text-sm leading-7 text-[var(--site-text-muted)] sm:text-base">
                Most inquiries get a reply within one business day. If the project is time-sensitive, call
                or text and include the date.
              </p>
            </div>
          </div>
        </div>

        <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
          <div class="max-w-xl">
            <span class="site-kicker">What to include</span>
            <h2 class="site-section-title mt-4">Enough detail to estimate cleanly.</h2>
            <p class="site-section-copy mt-4 max-w-lg">
              Keep it simple. A short note with the basics is enough to move the conversation forward.
            </p>
          </div>

          <ul class="space-y-5 border-l border-[var(--site-border)] pl-6 text-sm leading-7 text-[var(--site-text-muted)] sm:pl-8 sm:text-base">
              {inquiryPoints.map((point) => (
                <li class="flex items-start gap-3">
                  <Icon name="mdi:check-circle" class="mt-0.5 h-5 w-5 shrink-0 text-[var(--site-accent)]" />
                  <span>{point}</span>
                </li>
              ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
