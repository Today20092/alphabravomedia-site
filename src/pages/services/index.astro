---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../site-config";
import { formatGoogleReviewSummary } from "../../lib/google-business-profile";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
const reviewSummary = formatGoogleReviewSummary();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<BaseLayout title="Services & Retainers | Alpha Bravo Media">
  <section class="px-6 pb-12 pt-32 sm:pb-16 sm:pt-36">
    <div class="site-shell">
      <div class="site-page-header">
        <span class="site-kicker">Services</span>
        <h1 class="site-page-title max-w-4xl">
          Retainers and production packages built for ongoing marketing work first.
        </h1>
        <p class="site-page-copy text-lg">
          Monthly retainers lead the offer. Weddings, podcasts, and event A/V remain
          available for clients who need focused project support with the same
          production standard.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
        <div class="site-panel p-6 sm:p-8">
          <span class="site-kicker">Approach</span>
          <h2 class="site-section-title mt-4">
            The goal is steady publishing and clearer messaging, not just finished
            footage.
          </h2>
          <p class="site-section-copy mt-4">
            If the business needs consistent output, recurring strategy and production
            usually outperform one-off labor. Project work stays available when the job
            is more event-based or campaign-based.
          </p>
        </div>

        <div class="grid gap-4">
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-[var(--site-text)]">
              Retainers come first
            </p>
            <p class="mt-2 text-sm leading-7 text-[var(--site-text-muted)]">
              Film, edit, repurpose, and keep channels moving on a dependable cadence.
            </p>
          </div>
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-[var(--site-text)]">
              Premium project work stays available
            </p>
            <p class="mt-2 text-sm leading-7 text-[var(--site-text-muted)]">
              Weddings, podcasts, and events get the same attention when the scope
              needs a dedicated production block.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 pb-16 sm:pb-20">
    <div class="site-shell">
      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {sortedServices.map((service) => {
          const icon = service.data.icon ?? "mdi:star";
          const category = service.data.category ?? "Service";
          const startingPrice = service.data.tiers[0]?.value?.price ?? "";
          const topFeatures: string[] = (
            service.data.tiers[0]?.value?.includes ?? []
          ).slice(0, 3);

          return (
            <a
              href={`${base}services/${service.id}`}
              class="site-card site-card-interactive group flex flex-col"
            >
              <div class="site-card-body">
                <div class="flex items-start justify-between gap-4">
                  <span class="site-chip site-chip-muted">{category}</span>
                  <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-[var(--site-border)] bg-[rgba(255,255,255,0.03)] text-[var(--site-accent)]">
                    <Icon name={icon} class="h-5 w-5" />
                  </div>
                </div>
                <h2 class="site-card-title line-clamp-2">{service.data.title}</h2>
                <p class="site-card-copy line-clamp-2">{service.data.description}</p>
                <ul class="space-y-2 pt-2">
                  {topFeatures.map((feature) => (
                    <li class="flex items-start gap-2 text-sm leading-6 text-[var(--site-text-muted)]">
                      <Icon
                        name="mdi:check-circle"
                        class="mt-0.5 h-4 w-4 shrink-0 text-[var(--site-accent)]"
                      />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <div class="site-meta-row mt-auto justify-between pt-2">
                  <span>{startingPrice}</span>
                  <span class="text-[var(--site-accent)]">View packages</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="px-6 pb-24">
    <div class="site-shell">
      <div class="site-panel p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div>
            <span class="site-kicker">Next Step</span>
            <h2 class="site-section-title mt-4">Talk through the scope, timeline, and best fit.</h2>
            <p class="site-section-copy mt-4">
              The fastest route is direct contact. If the work fits a retainer, wedding,
              podcast, or event production package, the right service page will narrow
              the conversation quickly.
            </p>
            <div class="mt-5 flex flex-wrap items-center gap-2 text-sm text-[var(--site-text-muted)]">
              <Icon name="simple-icons:google" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>
                {reviewSummary ?? "Browse Google reviews before reaching out if you want outside proof first."}
              </span>
              <a
                href={siteConfig.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="site-link whitespace-nowrap"
              >
                Read reviews
              </a>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 lg:w-[19rem] lg:justify-self-end">
            <a href="mailto:contact@alphabravomedia.co" class="site-button-primary w-full">
              Email direct
            </a>
            <a href="tel:+18136650166" class="site-button-secondary w-full">
              Call (813) 665-0166
            </a>
            <a
              href={siteConfig.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="site-button-secondary w-full"
            >
              <Icon name="simple-icons:google" class="h-4 w-4" />
              {siteConfig.googleMapsLabel}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
