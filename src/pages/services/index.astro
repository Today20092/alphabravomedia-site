---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../site-config";
import { formatGoogleReviewSummary } from "../../lib/google-business-profile";
import FitCheckQuiz from "../../components/FitCheckQuiz.astro";
import ServicePreviewCard from "../../components/ServicePreviewCard.astro";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
const monthlyService = sortedServices.find((service) => service.id === "monthly-retainers");
const reviewSummary = formatGoogleReviewSummary();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<BaseLayout
  title="Video Production Services and Retainers | Alpha Bravo Media"
  description="Monthly retainers, podcast production, wedding coverage, and event support for Tampa businesses, creators, and community organizations."
>
  <section class="site-section-hero">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,0.92fr)] lg:items-end">
        <div class="site-page-header mb-0 max-w-3xl">
          <span class="site-kicker">Services</span>
          <h1 class="site-page-title">
            Find the right service before you book.
          </h1>
          <p class="site-page-copy max-w-2xl text-base sm:text-lg">
            Compare recurring content, podcast production, event support, and wedding coverage
            by fit, scope, and starting price so you can move forward without guessing.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={`${base}services/monthly-retainers`} class="site-button-primary">
              Start with retainers
            </a>
            <a href={`${base}portfolio`} class="site-button-secondary">
              Browse work
            </a>
          </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-site-text">Best fit</p>
            <p class="mt-3 text-sm leading-7 text-site-text-muted">
              Retainers fit brands that need ongoing content. The other offers fit podcast
              launches, live events, and wedding coverage.
            </p>
          </div>
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-site-text">What you&apos;ll see</p>
            <p class="mt-3 text-sm leading-7 text-site-text-muted">
              Every service page shows pricing, deliverables, sample work, FAQs, and the next
              step.
            </p>
          </div>
          <div class="site-panel-muted p-6 sm:col-span-2">
            <p class="text-sm font-semibold text-site-text">Why retainers lead</p>
            <p class="mt-3 text-sm leading-7 text-site-text-muted">
              If you need content every month, a retainer usually performs better than booking
              disconnected one-off shoots.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {monthlyService && (
    <section class="site-section">
      <div class="site-shell">
        <div class="site-panel p-6 sm:p-8">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
            <div>
              <span class="site-kicker">Primary offer</span>
              <h2 class="site-section-title mt-4">Monthly content retainers start at $1,200/mo.</h2>
              <p class="site-section-copy mt-4">
                Best for businesses that need recurring reels, brand imagery, message clarity,
                and a reliable content pipeline instead of another disconnected shoot.
              </p>
            </div>
            <a href={`${base}services/monthly-retainers`} class="site-button-primary">
              See retainer pricing
            </a>
          </div>
        </div>
      </div>
    </section>
  )}

  <section class="site-section">
    <div class="site-shell">
      <div class="mb-8 max-w-3xl">
        <span class="site-kicker">Offers</span>
        <h2 class="site-section-title mt-4">Compare offers before you commit.</h2>
        <p class="site-section-copy mt-4">
          Open the offer that fits your project to see pricing, scope, example work, FAQs, and
          the clearest next step.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {sortedServices.map((service) => (
          <ServicePreviewCard
            service={service}
            href={`${base}services/${service.id}`}
          />
        ))}
      </div>
    </div>
  </section>

  <FitCheckQuiz />

  <section class="site-section">
    <div class="site-shell">
      <div class="site-panel p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div>
            <span class="site-kicker">Contact</span>
            <h2 class="site-section-title mt-4">Talk scope and timing, then choose the right fit.</h2>
            <p class="site-section-copy mt-4">
              Start with the service page that fits best, or book a free consult to talk
              through the job before choosing a package.
            </p>
            <div class="mt-5 flex flex-wrap items-center gap-2 text-sm text-site-text-muted">
              <Icon name="simple-icons:google" class="h-4 w-4 text-site-accent" />
              <span>
                {reviewSummary ?? "Browse Google reviews before reaching out if you want outside proof first."}
              </span>
              <a
                href={siteConfig.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="site-link whitespace-nowrap"
              >
                Read reviews
              </a>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 lg:w-[19rem] lg:justify-self-end">
            <a href={`${base}contact`} class="site-button-primary w-full">
              Book consult
            </a>
            <a href={`tel:${siteConfig.phoneRaw}`} class="site-button-secondary w-full">
              Call Ayoub
            </a>
            <a href={`${base}portfolio`} class="site-button-secondary w-full">
              Browse work
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
