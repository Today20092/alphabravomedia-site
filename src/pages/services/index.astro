---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "../../site-config";
import { formatGoogleReviewSummary } from "../../lib/google-business-profile";
import FitCheckQuiz from "../../components/FitCheckQuiz.astro";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
const reviewSummary = formatGoogleReviewSummary();

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<BaseLayout
  title="Video Production Services and Retainers | Alpha Bravo Media"
  description="Monthly retainers, podcast production, wedding videography, and event A/V support for Tampa brands and creator-led businesses."
>
  <section class="site-section-hero">
    <div class="site-shell">
      <div class="site-page-header">
        <span class="site-kicker">Services</span>
        <h1 class="site-page-title max-w-3xl">
          Retainers and production packages for businesses that need consistent content.
        </h1>
        <p class="site-page-copy max-w-2xl text-base sm:text-lg">
          Monthly retainers lead the offer. Weddings, podcasts, and event A/V stay
          available for focused project support when the scope calls for it.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,0.8fr)]">
        <div class="site-panel p-6 sm:p-8">
          <span class="site-kicker">Approach</span>
          <h2 class="site-section-title mt-4">
            Consistency and clearer messaging beat one-off production when the brand
            needs momentum.
          </h2>
          <p class="site-section-copy mt-4">
            Recurring strategy and production usually create better results than
            isolated shoots. Project work stays available when the job is event-based or
            campaign-based.
          </p>
        </div>

        <div class="grid gap-4">
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-site-text">
              Keep the content pipeline moving
            </p>
            <p class="mt-2 text-sm leading-7 text-site-text-muted">
              Film, edit, repurpose, and publish on a dependable cadence.
            </p>
          </div>
          <div class="site-panel-muted p-6">
            <p class="text-sm font-semibold text-site-text">
              Focused project work stays available
            </p>
            <p class="mt-2 text-sm leading-7 text-site-text-muted">
              Weddings, podcasts, and events get the same attention when the scope
              needs a dedicated production block.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="site-section">
    <div class="site-shell">
      <div class="site-grid-4">
        {sortedServices.map((service) => {
          const icon = service.data.icon ?? "mdi:star";
          const category = service.data.category ?? "Service";
          const startingPrice = service.data.tiers[0]?.value?.price ?? "";
          const topFeatures: string[] = (
            service.data.tiers[0]?.value?.includes ?? []
          ).slice(0, 3);

          return (
            <a
              href={`${base}services/${service.id}`}
              class="site-card site-card-interactive group flex flex-col"
            >
              <div class="site-card-body">
                <div class="flex items-start justify-between gap-4">
                  <span class="site-chip site-chip-muted">{category}</span>
                  <div class="flex h-10 w-10 items-center justify-center rounded-2xl border border-site-border bg-site-control-bg text-site-accent">
                    <Icon name={icon} class="h-5 w-5" />
                  </div>
                </div>
                <h2 class="site-card-title line-clamp-2">{service.data.title}</h2>
                <p class="site-card-copy line-clamp-2">{service.data.description}</p>
                <ul class="space-y-2 pt-2">
                  {topFeatures.map((feature) => (
                    <li class="flex items-start gap-2 text-sm leading-6 text-site-text-muted">
                      <Icon
                        name="mdi:check-circle"
                        class="mt-0.5 h-4 w-4 shrink-0 text-site-accent"
                      />
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
                <div class="site-meta-row mt-auto justify-between pt-2">
                  <span>{startingPrice}</span>
                  <span class="text-site-accent">See package options</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <FitCheckQuiz />

  <section class="site-section">
    <div class="site-shell">
      <div class="site-panel p-6 sm:p-8">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_auto] lg:items-center">
          <div>
            <span class="site-kicker">Contact</span>
            <h2 class="site-section-title mt-4">Talk scope and timing, then choose the right fit.</h2>
            <p class="site-section-copy mt-4">
              Start with the service that fits best, or book a free 15-minute consult call to talk through your event, ask questions, or get advice before you commit.
            </p>
            <div class="mt-5 flex flex-wrap items-center gap-2 text-sm text-site-text-muted">
              <Icon name="simple-icons:google" class="h-4 w-4 text-site-accent" />
              <span>
                {reviewSummary ?? "Browse Google reviews before reaching out if you want outside proof first."}
              </span>
              <a
                href={siteConfig.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="site-link whitespace-nowrap"
              >
                Read reviews
              </a>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-1 lg:w-[19rem] lg:justify-self-end">
            <a href={`${base}contact`} class="site-button-primary w-full">
              Book consult
            </a>
            <a href="tel:+18136650166" class="site-button-secondary w-full">
              Call Ayoub
            </a>
            <a
              href={siteConfig.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="site-button-secondary w-full"
            >
              <Icon name="simple-icons:google" class="h-4 w-4" />
              {siteConfig.googleMapsLabel}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
