---
import { SEO } from "astro-seo";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Alpha Bravo Media | Cinema-Grade Videography",
  description = "Cinema-grade videography for brands and creators. High-quality video production and strategic content.",
  image = "/favicon.svg",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: image,
        },
      }}
      extend={{
        meta: [{ name: "generator", content: Astro.generator }],
      }}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0b0b0b] text-white font-['Inter',sans-serif] antialiased">
    <slot />
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
