---
import SearchModal from "../components/SearchModal.astro";
import { Icon } from "astro-icon/components";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "../site-config";

interface Props {
  title?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const youtubeLink = siteConfig.socialLinks.find(
  (s) => s.platform === "youtube",
);

const { title = `${siteConfig.siteName} | Cinema-Grade Videography`, ogImage, noIndex = false } =
  Astro.props;

// Base URL for GitHub Pages (or '/' for custom domain)
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const navLinks = [
  { href: base, label: "Home" },
  { href: `${base}services`, label: "Services" },
  { href: `${base}portfolio`, label: "Portfolio" },
  { href: `${base}blog`, label: "Blog" },
  { href: `${base}gallery`, label: "Gallery" },
  { href: `${base}gear`, label: "Gear" },
  { href: "#contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Cinema-grade videography for brands and creators. High-quality video production and strategic content."
    />
    <meta name="theme-color" content="#110f0d" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content={siteConfig.siteName} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {noIndex && <meta name="robots" content="noindex, nosnippet" />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
    <script is:inline>
      (() => {
        const storageKey = "abm-theme";
        const root = document.documentElement;
        const meta = document.querySelector('meta[name="theme-color"]');
        const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";

        let storedTheme = null;
        try {
          const value = localStorage.getItem(storageKey);
          if (value === "dark" || value === "light") {
            storedTheme = value;
          }
        } catch {
          storedTheme = null;
        }

        const theme = storedTheme ?? systemTheme;
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
        if (meta) {
          meta.setAttribute("content", theme === "dark" ? "#110f0d" : "#f4efe7");
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body class="bg-[var(--site-bg)] text-[var(--site-text)] font-['Inter',sans-serif] antialiased">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50">
      <nav class="site-shell-wide mt-4 rounded-[1.35rem] border border-[var(--site-border)] bg-[var(--site-nav-bg)] px-5 py-4 shadow-[var(--site-shadow-sm)] backdrop-blur">
        <div class="flex items-center justify-between gap-4">
          <!-- Logo -->
          <a
            href={base}
            class="font-['Sora',sans-serif] text-base font-semibold tracking-tight text-[var(--site-text)] transition-colors hover:text-[var(--site-accent-strong)] sm:text-lg"
          >
            {siteConfig.siteName}
          </a>

          <!-- Desktop Navigation -->
          <ul class="hidden md:flex items-center gap-6 lg:gap-8">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "font-['Sora',sans-serif] text-sm font-medium transition-colors duration-200",
                      currentPath === link.href
                        ? "text-[var(--site-text)]"
                        : "text-[var(--site-text-muted)] hover:text-[var(--site-text)]",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <!-- Theme Toggle (desktop) -->
          <button
            data-theme-toggle
            type="button"
            class="site-button-secondary site-theme-toggle hidden md:inline-flex"
            aria-pressed="true"
            aria-label="Toggle color theme"
          >
            <Icon name="mdi:weather-night" class="h-4 w-4" data-theme-icon="moon" />
            <Icon name="mdi:weather-sunny" class="h-4 w-4" data-theme-icon="sun" />
            <span data-theme-label>Dark</span>
          </button>

          <!-- Search Button (desktop) -->
          <button
            data-search-open
            class="hidden md:flex items-center gap-2 rounded-full border border-[var(--site-border)] px-3 py-2 text-sm font-medium text-[var(--site-text-muted)] transition-colors duration-200 hover:border-[var(--site-border-strong)] hover:text-[var(--site-text)]"
            aria-label="Open search (Ctrl+K)"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <kbd class="hidden font-mono text-xs text-[var(--site-text-soft)] lg:inline"
              >⌘K</kbd
            >
          </button>

          <!-- CTA Button -->
          {
            siteConfig.phoneRaw && (
              <a
                href={`tel:${siteConfig.phoneRaw}`}
                class="site-button-primary hidden md:inline-flex"
              >
                <Icon name="mdi:phone-outline" class="h-4 w-4" />
                Book a Call
              </a>
            )
          }

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="rounded-full border border-[var(--site-border)] p-2 text-[var(--site-text-muted)] transition-colors hover:text-[var(--site-text)] md:hidden"
            aria-label="Toggle menu"
          >
            <Icon id="menu-open" name="mdi:menu" class="w-6 h-6" />
            <Icon id="menu-close" name="mdi:close" class="w-6 h-6 hidden" />
          </button>
        </div>

        <!-- Mobile Navigation -->
        <div
          id="mobile-menu"
          class="mt-4 hidden border-t border-[var(--site-border)] pt-4 md:hidden"
        >
          <ul class="flex flex-col gap-4">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "block font-['Sora',sans-serif] text-sm font-medium transition-colors duration-200",
                      currentPath === link.href
                        ? "text-[var(--site-text)]"
                        : "text-[var(--site-text-muted)] hover:text-[var(--site-text)]",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
            <li>
              <button
                data-search-open
                class="flex w-full items-center gap-2 text-sm font-medium text-[var(--site-text-muted)] transition-colors hover:text-[var(--site-text)]"
              >
                <Icon name="mdi:magnify" class="w-4 h-4" />
                Search
              </button>
            </li>
            <li>
              <button
                data-theme-toggle
                type="button"
                class="site-button-secondary site-theme-toggle flex w-full justify-start"
                aria-pressed="true"
                aria-label="Toggle color theme"
              >
                <Icon name="mdi:weather-night" class="h-4 w-4" data-theme-icon="moon" />
                <Icon name="mdi:weather-sunny" class="h-4 w-4" data-theme-icon="sun" />
                <span data-theme-label>Dark</span>
              </button>
            </li>
            {
              youtubeLink && (
                <li>
                  <a
                    href={youtubeLink.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-sm font-medium text-[var(--site-text-muted)] transition-colors hover:text-[var(--site-text)]"
                  >
                    <Icon name={youtubeLink.icon} class="w-4 h-4" />
                    {youtubeLink.label}
                  </a>
                </li>
              )
            }
          </ul>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer
      id="contact"
      class="contact-highlight-target border-t border-[var(--site-border)] px-6 py-16 relative"
    >
      <div class="site-shell">
        <div
          id="contact-methods"
          class="mb-10 grid gap-8 rounded-[1.5rem] border border-[var(--site-border)] bg-[var(--site-surface)] p-6 transition-all duration-500 md:grid-cols-[1.1fr_1fr_0.9fr]"
        >
          <div
            class="rounded-xl transition-all duration-500"
            id="contact-brand-highlight"
          >
            <span class="site-kicker">Contact</span>
            <h2 class="mt-4 font-['Sora',sans-serif] text-2xl font-semibold tracking-tight text-[var(--site-text)]">
              {siteConfig.siteName}
            </h2>
            <p class="mt-3 max-w-[34ch] text-sm leading-7 text-[var(--site-text-muted)]">
              {siteConfig.tagline}
            </p>
          </div>

          <div class="grid gap-4 text-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
              Reach out
            </p>
            <a href={`mailto:${siteConfig.email}`} class="site-link flex items-center gap-3">
              <Icon name="mdi:email-outline" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>{siteConfig.email}</span>
            </a>
            <a href={`tel:${siteConfig.phoneRaw}`} class="site-link flex items-center gap-3">
              <Icon name="mdi:phone-outline" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>{siteConfig.phone}</span>
            </a>
            <a href={`sms:${siteConfig.phoneRaw}`} class="site-link flex items-center gap-3">
              <Icon name="mdi:message-outline" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>Text message</span>
            </a>
            <a
              href={`https://matrix.to/#/${siteConfig.elementUsername}`}
              target="_blank"
              rel="noopener noreferrer"
              class="site-link flex items-center gap-3"
            >
              <Icon name="simple-icons:element" class="h-4 w-4 text-[var(--site-accent)]" />
              <span class="font-mono text-xs sm:text-sm">{siteConfig.elementUsername}</span>
            </a>
          </div>

          <div class="grid gap-4 text-sm">
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-[var(--site-text-soft)]">
              Elsewhere
            </p>
            <a
              href={siteConfig.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="site-link flex items-center gap-3"
            >
              <Icon name="simple-icons:google" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>{siteConfig.googleMapsLabel}</span>
            </a>
            {
              siteConfig.socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="site-link flex items-center gap-3"
                >
                  <Icon name={link.icon} class="h-4 w-4 text-[var(--site-accent)]" />
                  <span>{link.label}</span>
                </a>
              ))
            }
            <a
              href="https://discord.gg/p4QP7zTkv8"
              target="_blank"
              rel="noopener noreferrer"
              class="site-link flex items-center gap-3"
            >
              <Icon name="simple-icons:discord" class="h-4 w-4 text-[var(--site-accent)]" />
              <span>Creator community</span>
            </a>
          </div>
        </div>

        <div class="flex flex-col gap-3 border-t border-[var(--site-border)] pt-6 text-sm text-[var(--site-text-soft)] sm:flex-row sm:items-center sm:justify-between">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-6">
            <p>
              &copy; {new Date().getFullYear()} {siteConfig.siteName}. All rights reserved.
            </p>
            <a href={`${base}terms`} class="site-link">Terms of Service</a>
          </div>
          <p>Based in Tampa, serving brands, creators, and events.</p>
        </div>
      </div>
    </footer>

    <SearchModal />

    <!-- Scripts -->
    <script>
      let lastScrollY = window.scrollY;
      const themeStorageKey = "abm-theme";
      const themeColors = {
        dark: "#110f0d",
        light: "#f4efe7",
      };

      function handleScroll() {
        const header = document.querySelector("header");
        if (!header) return;

        const currentScrollY = window.scrollY;

        // Only hide header if scrolled down past 100px
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          header.style.transform = "translateY(-100%)";
        } else {
          header.style.transform = "translateY(0)";
        }
        lastScrollY = currentScrollY;
      }

      function getStoredTheme() {
        try {
          const value = localStorage.getItem(themeStorageKey);
          if (value === "dark" || value === "light") return value;
        } catch {
          return null;
        }

        return null;
      }

      function getSystemTheme() {
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      }

      function applyTheme(theme) {
        const root = document.documentElement;
        const meta = document.querySelector('meta[name="theme-color"]');

        root.dataset.theme = theme;
        root.style.colorScheme = theme;

        if (meta) {
          meta.setAttribute("content", themeColors[theme]);
        }

        document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
          button.setAttribute("aria-pressed", theme === "dark" ? "true" : "false");
          button.setAttribute(
            "aria-label",
            theme === "dark" ? "Switch to light theme" : "Switch to dark theme",
          );

          const label = button.querySelector("[data-theme-label]");
          if (label) {
            label.textContent = theme === "dark" ? "Dark" : "Light";
          }
        });
      }

      function setupThemeToggle() {
        applyTheme(getStoredTheme() ?? getSystemTheme());

        if (window.__abmThemeChangeHandler) {
          document.removeEventListener("click", window.__abmThemeChangeHandler);
        }

        window.__abmThemeChangeHandler = (event) => {
          if (!(event.target instanceof Element)) return;
          const button = event.target.closest("[data-theme-toggle]");
          if (!button) return;

          event.preventDefault();

          const currentTheme =
            document.documentElement.dataset.theme === "light" ? "light" : "dark";
          const nextTheme = currentTheme === "dark" ? "light" : "dark";

          try {
            localStorage.setItem(themeStorageKey, nextTheme);
          } catch {
            // Ignore storage failures and keep the current theme in memory.
          }

          applyTheme(nextTheme);
        };

        document.addEventListener("click", window.__abmThemeChangeHandler);

        if (window.__abmThemeMediaQuery && window.__abmThemeMediaHandler) {
          window.__abmThemeMediaQuery.removeEventListener(
            "change",
            window.__abmThemeMediaHandler,
          );
        }

        window.__abmThemeMediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
        window.__abmThemeMediaHandler = () => {
          if (!getStoredTheme()) {
            applyTheme(getSystemTheme());
          }
        };
        window.__abmThemeMediaQuery.addEventListener(
          "change",
          window.__abmThemeMediaHandler,
        );
      }

      function setupInteractions() {
        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const menuOpen = document.getElementById("menu-open");
        const menuClose = document.getElementById("menu-close");

        mobileMenuBtn?.addEventListener("click", () => {
          const isHidden = mobileMenu?.classList.contains("hidden");

          if (isHidden) {
            mobileMenu?.classList.remove("hidden");
            menuOpen?.classList.add("hidden");
            menuClose?.classList.remove("hidden");
          } else {
            mobileMenu?.classList.add("hidden");
            menuOpen?.classList.remove("hidden");
            menuClose?.classList.add("hidden");
          }
        });

        // Setup Header transition
        const header = document.querySelector("header");
        if (header) {
          header.style.transition = "transform 0.3s ease-in-out";
        }

        // Header scroll behavior
        lastScrollY = window.scrollY;
        window.removeEventListener("scroll", handleScroll);
        window.addEventListener("scroll", handleScroll, { passive: true });

        // Handle contact highlight without causing page reload/transitions
        const contactLinks = document.querySelectorAll('a[href$="#contact"]');
        contactLinks.forEach((link) => {
          link.addEventListener("click", () => {
            const targets = document.querySelectorAll(
              ".contact-highlight-target",
            );
            targets.forEach((el) => {
              el.classList.remove("highlight-glow-animation");
              void (el as HTMLElement).offsetWidth; // trigger reflow
              el.classList.add("highlight-glow-animation");
            });

            setTimeout(() => {
              targets.forEach((el) =>
                el.classList.remove("highlight-glow-animation"),
              );
            }, 3000);
          });
        });
      }

      // Run on initial load and after view transitions
      setupThemeToggle();
      document.addEventListener("astro:page-load", setupInteractions);
      document.addEventListener("astro:page-load", setupThemeToggle);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  @keyframes contact-glow-pulse {
    0% {
      background-color: transparent;
      box-shadow: inset 0 0 0 0px color-mix(in oklab, var(--site-accent) 0%, transparent);
    }
    15% {
      background-color: var(--site-accent-soft);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklab, var(--site-accent) 26%, transparent),
        inset 0 18px 30px -24px color-mix(in oklab, var(--site-accent) 20%, transparent);
    }
    85% {
      background-color: var(--site-accent-soft);
      box-shadow:
        inset 0 0 0 1px color-mix(in oklab, var(--site-accent) 26%, transparent),
        inset 0 18px 30px -24px color-mix(in oklab, var(--site-accent) 20%, transparent);
    }
    100% {
      background-color: transparent;
      box-shadow: inset 0 0 0 0px color-mix(in oklab, var(--site-accent) 0%, transparent);
    }
  }

  .highlight-glow-animation {
    animation: contact-glow-pulse 2.5s cubic-bezier(0.34, 1.56, 0.64, 1)
      forwards;
  }
</style>
