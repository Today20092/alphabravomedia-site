---
import SearchModal from "../components/SearchModal.astro";
import { Icon } from "astro-icon/components";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
}

// ============================================
// SITE CONFIG - Edit your info here
// ============================================
const siteConfig = {
  // Brand
  siteName: "Alpha Bravo Media",
  tagline: "Cinema-grade videography for brands and creators.",

  // Contact
  email: "contact@alphabravomedia.co",
  phone: "(813) 665-0166",
  phoneRaw: "+18136650166", // For tel: link (no spaces/dashes)
  elementUsername: "@ayoubab:matrix.org",

  // Social Links
  socialLinks: [
    {
      platform: "youtube",
      label: "YouTube",
      href: "https://youtube.com/@alphabravomedia",
      icon: "simple-icons:youtube",
    },
    {
      platform: "instagram",
      label: "Instagram",
      href: "https://instagram.com/alphabravomedia",
      icon: "simple-icons:instagram",
    },
    // {
    //   platform: "twitter",
    //   label: "Twitter/X",
    //   href: "https://twitter.com/alphabravomedia",
    //   icon: "simple-icons:x",
    // },
  ],
};
// ============================================

const youtubeLink = siteConfig.socialLinks.find(
  (s) => s.platform === "youtube",
);

const { title = `${siteConfig.siteName} | Cinema-Grade Videography` } =
  Astro.props;

// Base URL for GitHub Pages (or '/' for custom domain)
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const navLinks = [
  { href: base, label: "Home" },
  { href: `${base}portfolio`, label: "Portfolio" },
  { href: `${base}blog`, label: "Blog" },
  { href: `${base}gallery`, label: "Gallery" },
  { href: `${base}gear`, label: "Gear" },
  { href: "#contact", label: "Contact" },
];

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Cinema-grade videography for brands and creators. High-quality video production and strategic content."
    />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href={`${base}pagefind/pagefind-ui.css`} />
    <ClientRouter />
  </head>
  <body class="bg-[#0b0b0b] text-white font-['Inter',sans-serif] antialiased">
    <!-- Navigation -->
    <header class="fixed top-0 left-0 right-0 z-50">
      <nav
        class="mx-4 mt-4 px-6 py-4 rounded-2xl bg-white/5 backdrop-blur-xl border border-[#2a2520] shadow-lg shadow-black/20"
      >
        <div class="max-w-6xl mx-auto flex items-center justify-between">
          <!-- Logo -->
          <a
            href={base}
            class="text-lg font-semibold tracking-tight text-white hover:text-gray-300 transition-colors font-['Sora',sans-serif]"
          >
            {siteConfig.siteName}
          </a>

          <!-- Desktop Navigation -->
          <ul class="hidden md:flex items-center gap-8">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "text-sm font-medium transition-colors duration-200 font-['Sora',sans-serif]",
                      currentPath === link.href
                        ? "text-white"
                        : "text-[#a8998a] hover:text-white",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>

          <!-- Search Button (desktop) -->
          <button
            data-search-open
            class="hidden md:flex items-center gap-2 px-3 py-2 text-[#a8998a] hover:text-white hover:bg-white/10 rounded-full text-sm font-medium transition-colors duration-200"
            aria-label="Open search (Ctrl+K)"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <kbd class="hidden lg:inline text-xs text-[#7a6f63] font-mono"
              >⌘K</kbd
            >
          </button>

          <!-- CTA Button -->
          {
            youtubeLink && (
              <a
                href={youtubeLink.href}
                target="_blank"
                rel="noopener noreferrer"
                class="hidden md:flex items-center gap-2 px-4 py-2 bg-white/10 hover:bg-white/15 rounded-full text-sm font-medium text-white transition-colors duration-200"
              >
                <Icon name={youtubeLink.icon} class="w-4 h-4" />
                {youtubeLink.label}
              </a>
            )
          }

          <!-- Mobile Menu Button -->
          <button
            id="mobile-menu-btn"
            class="md:hidden p-2 text-[#a8998a] hover:text-white transition-colors"
            aria-label="Toggle menu"
          >
            <Icon id="menu-open" name="mdi:menu" class="w-6 h-6" />
            <Icon id="menu-close" name="mdi:close" class="w-6 h-6 hidden" />
          </button>
        </div>

        <!-- Mobile Navigation -->
        <div
          id="mobile-menu"
          class="hidden md:hidden mt-4 pt-4 border-t border-[#2a2520]"
        >
          <ul class="flex flex-col gap-4">
            {
              navLinks.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "block text-sm font-medium transition-colors duration-200 font-['Sora',sans-serif]",
                      currentPath === link.href
                        ? "text-white"
                        : "text-[#a8998a] hover:text-white",
                    ]}
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
            <li>
              <button
                data-search-open
                class="flex items-center gap-2 text-sm font-medium text-[#a8998a] hover:text-white transition-colors w-full"
              >
                <Icon name="mdi:magnify" class="w-4 h-4" />
                Search
              </button>
            </li>
            {
              youtubeLink && (
                <li>
                  <a
                    href={youtubeLink.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex items-center gap-2 text-sm font-medium text-[#a8998a] hover:text-white transition-colors"
                  >
                    <Icon name={youtubeLink.icon} class="w-4 h-4" />
                    {youtubeLink.label}
                  </a>
                </li>
              )
            }
          </ul>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer
      id="contact"
      class="py-16 px-6 border-t border-[#2a2520] bg-[#080808] contact-highlight-target relative"
    >
      <div class="max-w-6xl mx-auto">
        <!-- Contact Section -->
        <div
          id="contact-methods"
          class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12 rounded-2xl transition-all duration-500"
        >
          <!-- Brand -->
          <div
            class="lg:col-span-1 p-4 -m-4 rounded-xl transition-all duration-500"
            id="contact-brand-highlight"
          >
            <h3
              class="text-xl font-semibold tracking-tight text-white mb-3 font-['Sora',sans-serif]"
            >
              {siteConfig.siteName}
            </h3>
            <p class="text-sm text-[#7a6f63] leading-relaxed">
              {siteConfig.tagline}
            </p>
          </div>

          <!-- Email -->
          <div class="p-4 -m-4 rounded-xl transition-all duration-500">
            <h4
              class="text-sm font-semibold text-[#a8998a] uppercase tracking-wider mb-3"
            >
              Email
            </h4>
            <a
              href={`mailto:${siteConfig.email}`}
              class="group flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors"
            >
              <Icon
                name="mdi:email-outline"
                class="w-5 h-5 text-[#7a6f63] group-hover:text-white transition-colors"
              />
              <span class="text-sm">{siteConfig.email}</span>
            </a>
          </div>

          <!-- Phone -->
          <div class="p-4 -m-4 rounded-xl transition-all duration-500">
            <h4
              class="text-sm font-semibold text-[#a8998a] uppercase tracking-wider mb-3"
            >
              Phone
            </h4>
            <a
              href={`tel:${siteConfig.phoneRaw}`}
              class="group flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors"
            >
              <Icon
                name="mdi:phone-outline"
                class="w-5 h-5 text-[#7a6f63] group-hover:text-white transition-colors"
              />
              <span class="text-sm">{siteConfig.phone}</span>
            </a>
            <p class="text-xs text-[#7a6f63] mt-1 ml-7">Google Voice</p>
            <a
              href={`sms:${siteConfig.phoneRaw}`}
              class="group flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors mt-2"
            >
              <Icon
                name="mdi:message-outline"
                class="w-5 h-5 text-[#7a6f63] group-hover:text-white transition-colors"
              />
              <span class="text-sm">{siteConfig.phone}</span>
            </a>
            <p class="text-xs text-[#7a6f63] mt-1 ml-7">Text</p>
          </div>

          <!-- Element -->
          <div class="p-4 -m-4 rounded-xl transition-all duration-500">
            <h4
              class="text-sm font-semibold text-[#a8998a] uppercase tracking-wider mb-3"
            >
              Element / Matrix
            </h4>
            <a
              href={`https://matrix.to/#/${siteConfig.elementUsername}`}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-2 text-[#a8998a] hover:text-white transition-colors"
            >
              <Icon
                name="simple-icons:element"
                class="w-5 h-5 text-[#7a6f63] group-hover:text-white transition-colors"
              />
              <span class="text-sm font-mono">{siteConfig.elementUsername}</span
              >
            </a>
            <p class="text-xs text-[#7a6f63] mt-1 ml-7">Opens in Element</p>
          </div>
        </div>

        <!-- Bottom Bar -->
        <div
          class="pt-8 border-t border-[#2a2520] flex flex-col sm:flex-row items-center justify-between gap-4"
        >
          <div class="flex flex-col sm:flex-row items-center gap-2 sm:gap-6">
            <p class="text-[#7a6f63] text-sm">
              &copy; {new Date().getFullYear()}
              {siteConfig.siteName}. All rights reserved.
            </p>
            <a
              href={`${base}terms`}
              class="text-[#7a6f63] hover:text-white text-sm transition-colors mt-2 sm:mt-0"
            >
              Terms of Service
            </a>
          </div>
          <div class="flex items-center gap-6">
            {
              siteConfig.socialLinks.map((link) => (
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[#7a6f63] hover:text-white transition-colors"
                  aria-label={link.label}
                >
                  <Icon name={link.icon} class="w-5 h-5" />
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </footer>

    <SearchModal />

    <!-- Scripts -->
    <script>
      let lastScrollY = window.scrollY;

      function handleScroll() {
        const header = document.querySelector("header");
        if (!header) return;

        const currentScrollY = window.scrollY;

        // Only hide header if scrolled down past 100px
        if (currentScrollY > lastScrollY && currentScrollY > 100) {
          header.style.transform = "translateY(-100%)";
        } else {
          header.style.transform = "translateY(0)";
        }
        lastScrollY = currentScrollY;
      }

      function setupInteractions() {
        // Mobile menu toggle
        const mobileMenuBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const menuOpen = document.getElementById("menu-open");
        const menuClose = document.getElementById("menu-close");

        mobileMenuBtn?.addEventListener("click", () => {
          const isHidden = mobileMenu?.classList.contains("hidden");

          if (isHidden) {
            mobileMenu?.classList.remove("hidden");
            menuOpen?.classList.add("hidden");
            menuClose?.classList.remove("hidden");
          } else {
            mobileMenu?.classList.add("hidden");
            menuOpen?.classList.remove("hidden");
            menuClose?.classList.add("hidden");
          }
        });

        // Setup Header transition
        const header = document.querySelector("header");
        if (header) {
          header.style.transition = "transform 0.3s ease-in-out";
        }

        // Header scroll behavior
        lastScrollY = window.scrollY;
        window.removeEventListener("scroll", handleScroll);
        window.addEventListener("scroll", handleScroll, { passive: true });

        // Handle contact highlight without causing page reload/transitions
        const contactLinks = document.querySelectorAll('a[href$="#contact"]');
        contactLinks.forEach((link) => {
          link.addEventListener("click", () => {
            const targets = document.querySelectorAll(
              ".contact-highlight-target",
            );
            targets.forEach((el) => {
              el.classList.remove("highlight-glow-animation");
              void (el as HTMLElement).offsetWidth; // trigger reflow
              el.classList.add("highlight-glow-animation");
            });

            setTimeout(() => {
              targets.forEach((el) =>
                el.classList.remove("highlight-glow-animation"),
              );
            }, 3000);
          });
        });
      }

      // Run on initial load and after view transitions
      document.addEventListener("astro:page-load", setupInteractions);
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  @keyframes contact-glow-pulse {
    0% {
      background-color: #080808;
      box-shadow: inset 0 0 0 0px rgba(200, 135, 92, 0);
    }
    15% {
      background-color: rgba(200, 135, 92, 0.05);
      box-shadow:
        inset 0 0 0 1px rgba(200, 135, 92, 0.2),
        inset 0 20px 40px -20px rgba(200, 135, 92, 0.15);
    }
    85% {
      background-color: rgba(200, 135, 92, 0.05);
      box-shadow:
        inset 0 0 0 1px rgba(200, 135, 92, 0.2),
        inset 0 20px 40px -20px rgba(200, 135, 92, 0.15);
    }
    100% {
      background-color: #080808;
      box-shadow: inset 0 0 0 0px rgba(200, 135, 92, 0);
    }
  }

  .highlight-glow-animation {
    animation: contact-glow-pulse 2.5s cubic-bezier(0.34, 1.56, 0.64, 1)
      forwards;
  }
</style>
