---
import { Image } from "astro:assets";

interface Props {
  images: Array<{
    src: ImageMetadata | string;
    alt: string;
    caption?: string;
    fullSrc?: string;
  }>;
  layout?: 'square' | 'natural' | 'masonry';
}

const { images, layout = 'square' } = Astro.props;
const id = `gallery-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="not-prose my-8">
  <!-- Thumbnail grid -->
  {layout === 'masonry' ? (
    <div id={id} class="columns-2 md:columns-3 gap-3">
      {images.map((image, i) => (
        <button
          class="gallery-thumb site-card relative mb-3 block w-full cursor-zoom-in break-inside-avoid overflow-hidden"
          data-index={i}
          data-full={image.fullSrc ?? ''}
          aria-label={`Open photo ${i + 1} of ${images.length}`}
        >
          {typeof image.src === 'string' ? (
            <img src={image.src} alt={image.alt} loading="lazy" decoding="async" class="block h-auto w-full" />
          ) : (
            <Image src={image.src} alt={image.alt} class="block h-auto w-full" />
          )}
          <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-white/10" />
          <div class="absolute inset-0 rounded-xl bg-black/0 transition-colors duration-300 group-hover:bg-black/10" />
          {image.caption && (
            <div class="absolute bottom-0 left-0 right-0 translate-y-full bg-black/60 p-3 transition-transform duration-300 ease-in-out group-hover:translate-y-0">
              <p class="text-sm text-white/90 font-medium text-center m-0 leading-tight">
                {image.caption}
              </p>
            </div>
          )}
        </button>
      ))}
    </div>
  ) : (
    <div id={id} class="grid grid-cols-2 md:grid-cols-3 gap-3">
      {images.map((image, i) => (
        <button
          class={`gallery-thumb site-card relative cursor-zoom-in overflow-hidden${layout === 'square' ? ' aspect-square' : ''}`}
          data-index={i}
          data-full={image.fullSrc ?? ''}
          aria-label={`Open photo ${i + 1} of ${images.length}`}
        >
          {typeof image.src === 'string' ? (
            <img src={image.src} alt={image.alt} loading="lazy" decoding="async" class={layout === 'square' ? 'h-full w-full object-cover' : 'block h-auto w-full'} />
          ) : (
            <Image src={image.src} alt={image.alt} class={layout === 'square' ? 'h-full w-full object-cover' : 'block h-auto w-full'} />
          )}
          <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-white/10" />
          <div class="absolute inset-0 rounded-xl bg-black/0 transition-colors duration-300 group-hover:bg-black/10" />
          {image.caption && (
            <div class="absolute bottom-0 left-0 right-0 translate-y-full bg-black/60 p-3 transition-transform duration-300 ease-in-out group-hover:translate-y-0">
              <p class="text-sm text-white/90 font-medium text-center m-0 leading-tight">
                {image.caption}
              </p>
            </div>
          )}
        </button>
      ))}
    </div>
  )}
</div>

{images.length > 50 && (
  <div id={`${id}-load-more-wrap`} class="flex justify-center mt-8">
    <button
      id={`${id}-load-more`}
      class="site-button-secondary"
    >
      Load more photos
    </button>
  </div>
)}

<!-- Lightbox -->
<div
  id={`${id}-lightbox`}
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90"
  role="dialog"
  aria-modal="true"
  aria-label="Image lightbox"
>
  <!-- Download -->
  <a
    class="lightbox-download absolute right-16 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white transition-colors hover:bg-white/20"
    href=""
    download
    aria-label="Download photo"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
  </a>

  <!-- Close -->
  <button
    class="lightbox-close absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white transition-colors hover:bg-white/20"
    aria-label="Close lightbox"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>

  <!-- Prev -->
  <button
    class="lightbox-prev absolute left-3 z-10 flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white transition-colors hover:bg-white/20 disabled:opacity-30 md:left-6"
    aria-label="Previous image"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
  </button>

  <!-- Image container -->
  <div class="relative max-w-5xl max-h-[90vh] w-full px-16 flex items-center justify-center">
    <img
      class="lightbox-img max-h-[85vh] max-w-full rounded-lg object-contain transition-opacity duration-200"
      src=""
      alt=""
    />
  </div>

  <!-- Next -->
  <button
    class="lightbox-next absolute right-3 z-10 flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/10 text-white transition-colors hover:bg-white/20 md:right-6"
    aria-label="Next image"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
  </button>

  <!-- Counter -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/50 text-sm tabular-nums">
    <span class="lightbox-current">1</span> / <span class="lightbox-total">{images.length}</span>
  </div>
</div>

<script define:vars={{ id, imageCount: images.length, pageSize: 50 }}>
  (function () {
    const grid = document.getElementById(id);
    const lightbox = document.getElementById(`${id}-lightbox`);
    if (!grid || !lightbox) return;

    const img = lightbox.querySelector(".lightbox-img");
    const current = lightbox.querySelector(".lightbox-current");
    const thumbs = Array.from(grid.querySelectorAll(".gallery-thumb"));

    // Pagination — hide thumbs beyond first page
    let shown = Math.min(pageSize, imageCount);
    thumbs.forEach((btn, i) => {
      if (i >= pageSize) btn.style.display = "none";
    });
    const loadMoreWrap = document.getElementById(`${id}-load-more-wrap`);
    const loadMoreBtn = document.getElementById(`${id}-load-more`);
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener("click", () => {
        const next = Math.min(shown + pageSize, imageCount);
        for (let i = shown; i < next; i++) thumbs[i].style.display = "";
        shown = next;
        if (shown >= imageCount && loadMoreWrap) loadMoreWrap.style.display = "none";
        else if (loadMoreBtn) loadMoreBtn.textContent = `Load more photos (${imageCount - shown} remaining)`;
      });
      if (imageCount > pageSize) loadMoreBtn.textContent = `Load more photos (${imageCount - pageSize} remaining)`;
    }

    // Collect src, alt, and full-res URL from each thumb
    const srcs = thumbs.map((btn) => {
      const i = btn.querySelector("img");
      return {
        src: i?.src ?? "",
        alt: i?.alt ?? "",
        full: btn.dataset.full || i?.src || "",
      };
    });

    let index = 0;

    const downloadLink = lightbox.querySelector(".lightbox-download");

    function show(i) {
      index = (i + imageCount) % imageCount;
      img.style.opacity = "0";
      setTimeout(() => {
        img.src = srcs[index].src;
        img.alt = srcs[index].alt;
        if (downloadLink) downloadLink.href = srcs[index].full;
        if (current) current.textContent = String(index + 1);
        img.style.opacity = "1";
      }, 150);
      lightbox.querySelector(".lightbox-prev").disabled = false;
      lightbox.querySelector(".lightbox-next").disabled = false;
    }

    function open(i) {
      show(i);
      lightbox.classList.remove("hidden");
      lightbox.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function close() {
      lightbox.classList.add("hidden");
      lightbox.classList.remove("flex");
      document.body.style.overflow = "";
    }

    thumbs.forEach((btn, i) => btn.addEventListener("click", () => open(i)));
    lightbox.querySelector(".lightbox-close").addEventListener("click", close);
    lightbox.querySelector(".lightbox-prev").addEventListener("click", () => show(index - 1));
    lightbox.querySelector(".lightbox-next").addEventListener("click", () => show(index + 1));

    // Close on backdrop click
    lightbox.addEventListener("click", (e) => {
      if (e.target === lightbox) close();
    });

    // Keyboard nav
    document.addEventListener("keydown", (e) => {
      if (lightbox.classList.contains("hidden")) return;
      if (e.key === "ArrowRight") show(index + 1);
      else if (e.key === "ArrowLeft") show(index - 1);
      else if (e.key === "Escape") close();
    });
  })();
</script>
