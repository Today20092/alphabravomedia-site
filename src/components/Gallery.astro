---
import { Image } from "astro:assets";

interface Props {
  images: Array<{
    src: ImageMetadata;
    alt: string;
    caption?: string;
  }>;
}

const { images } = Astro.props;
---

<div class="not-prose my-8 grid grid-cols-2 md:grid-cols-3 gap-4">
  {
    images.map((image) => (
      <div class="relative group aspect-square overflow-hidden rounded-xl shadow-lg bg-gray-900 border border-gray-800">
        <Image
          src={image.src}
          alt={image.alt}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-xl pointer-events-none" />
        {image.caption && (
          <div class="absolute bottom-0 left-0 right-0 bg-black/60 backdrop-blur-md p-3 translate-y-0 md:translate-y-full md:group-hover:translate-y-0 transition-transform duration-300 ease-in-out">
            <p class="text-sm text-white/90 font-medium text-center m-0 leading-tight">
              {image.caption}
            </p>
          </div>
        )}
      </div>
    ))
  }
</div>
