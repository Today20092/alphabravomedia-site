---
import { Image } from "astro:assets";

interface Props {
  images: Array<{
    src: ImageMetadata;
    alt: string;
  }>;
}

const { images } = Astro.props;
---

<div class="not-prose my-8 grid grid-cols-2 md:grid-cols-3 gap-4">
  {
    images.map((image) => (
      <div class="relative group aspect-square overflow-hidden rounded-xl shadow-lg bg-gray-900 border border-gray-800">
        <Image
          src={image.src}
          alt={image.alt}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
        <div class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-xl" />
      </div>
    ))
  }
</div>
