---
export interface Props {
  name: string;
  price: string;
  bestFor: string;
  isPopular?: boolean;
  includes: string[];
}

const { name, price, bestFor, isPopular = false, includes } = Astro.props;
import { Icon } from "astro-icon/components";
---

<div
  class={`relative flex flex-col p-6 sm:p-8 rounded-2xl border transition-all duration-300 h-full ${
    isPopular
      ? "bg-gray-900 border-gray-600 shadow-xl shadow-white/5 scale-100 md:scale-105 z-10"
      : "bg-gray-900/50 border-gray-800 hover:border-gray-700"
  }`}
>
  {
    isPopular && (
      <div class="absolute -top-4 left-1/2 -translate-x-1/2">
        <span class="bg-white text-black text-xs font-bold uppercase tracking-wider py-1 px-3 rounded-full">
          Recommended
        </span>
      </div>
    )
  }

  <div class="mb-8">
    <h3 class="text-xl font-bold text-white mb-2">{name}</h3>
    <div class="text-3xl font-bold text-white mb-4">{price}</div>
    <div
      class="text-sm font-medium text-gray-400 bg-gray-800/50 rounded-lg p-3 inline-block"
    >
      <span class="block text-gray-500 text-xs uppercase tracking-wider mb-1"
        >Best For</span
      >
      {bestFor}
    </div>
  </div>

  <div class="flex-grow">
    <h4
      class="text-sm font-semibold text-gray-300 uppercase tracking-wider mb-4"
    >
      What's Included
    </h4>
    <ul class="space-y-3 mb-8">
      {
        includes.map((item) => (
          <li class="flex items-start">
            <Icon
              name="mdi:check-circle"
              class="w-5 h-5 text-gray-400 mr-3 shrink-0 mt-0.5"
            />
            <span class="text-gray-300 text-sm leading-relaxed">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-auto">
    <a
      href="#contact"
      class={`block w-full text-center py-3 px-4 rounded-xl font-semibold transition-all duration-300 ${
        isPopular
          ? "bg-white text-black hover:bg-gray-200"
          : "bg-gray-800 text-white hover:bg-gray-700"
      }`}
    >
      Inquire Now
    </a>
  </div>
</div>
