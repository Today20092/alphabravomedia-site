---
import { Icon } from "astro-icon/components";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

export interface Props {
  name: string;
  price: string;
  bestFor: string;
  isPopular?: boolean;
  includes: string[];
}

const { name, price, bestFor, isPopular = false, includes } = Astro.props;
---

<div
  class:list={[
    "site-card flex h-full w-[calc(100vw-2rem)] max-w-[22rem] flex-none snap-start flex-col p-6 sm:p-8 md:w-auto md:max-w-none md:flex-auto",
    isPopular
      ? "border-site-border-strong bg-site-surface-muted shadow-site-sm"
      : "site-card-interactive",
  ]}
>
  <div class="mb-8 flex items-start justify-between gap-4">
    <div>
      <div class="flex items-center gap-3">
        <h3 class="site-card-title text-xl">{name}</h3>
        {isPopular && <span class="site-chip">Recommended</span>}
      </div>
      <p class="mt-3 text-3xl font-bold text-site-text">{price}</p>
    </div>
  </div>

  <div class="site-panel-muted mb-8 p-4">
    <p class="text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
      Best for
    </p>
    <p class="mt-2 text-sm leading-7 text-site-text-muted">{bestFor}</p>
  </div>

  <div class="grow">
    <h4 class="mb-4 text-xs font-semibold uppercase tracking-[0.24em] text-site-text-soft">
      Included
    </h4>
    <ul class="space-y-3">
      {
        includes.map((item) => (
          <li class="flex items-start gap-3">
            <Icon
              name="mdi:check-circle"
              class="mt-0.5 h-5 w-5 shrink-0 text-site-accent"
            />
            <span class="text-sm leading-7 text-site-text-muted">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mt-8">
    <a
      href={`${base}contact`}
      class:list={[
        "w-full",
        isPopular ? "site-button-primary" : "site-button-secondary",
      ]}
    >
      Ask about {name}
    </a>
  </div>
</div>
