---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<section id="services-teaser" class="border-t border-[var(--site-border)] px-6 py-20 sm:py-24">
  <div class="site-shell">
    <div class="mb-10 grid gap-4">
      <span class="site-kicker">Services</span>
      <h2 class="site-section-title max-w-3xl">
        Retainers first, project work second, and every package built to keep the
        message clear.
      </h2>
      <p class="site-section-copy">
        Monthly content plans lead the offer. Weddings, podcasts, and event A/V stay
        available for clients that need focused project support.
      </p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {sortedServices.map((service) => {
        const icon = service.data.icon ?? "mdi:star";
        const startingPrice = service.data.tiers[0]?.value?.price ?? "";

        return (
          <a
            href={`${base}services/${service.id}`}
            class="site-card site-card-interactive group flex flex-col"
          >
            <div class="site-card-body">
              <span class="site-chip site-chip-muted w-fit">
                {service.data.category ?? "Service"}
              </span>
              <div class="flex h-11 w-11 items-center justify-center rounded-2xl border border-[var(--site-border)] bg-[rgba(255,255,255,0.03)] text-[var(--site-accent)]">
                <Icon name={icon} class="h-5 w-5" />
              </div>
              <h3 class="site-card-title">{service.data.title}</h3>
              <p class="site-card-copy line-clamp-2">{service.data.description}</p>
              <div class="site-meta-row mt-auto justify-between">
                <span>{startingPrice}</span>
                <span class="text-[var(--site-accent)]">View details</span>
              </div>
            </div>
          </a>
        );
      })}
    </div>

    <div class="mt-8">
      <a href={`${base}services`} class="site-button-primary">
        View services and retainers
        <Icon name="mdi:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
