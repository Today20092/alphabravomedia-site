---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import ServicePreviewCard from "./ServicePreviewCard.astro";

interface Props {
  title?: string;
  description?: string;
  excludeIds?: string[];
}

const {
  title = "Focused project work when the brief needs a dedicated production block.",
  description = "Podcast production, live event support, and weddings stay available when recurring content is not the right fit.",
  excludeIds = [],
} = Astro.props;

const allServices = await getCollection("services");
const sortedServices = allServices
  .sort((a, b) => a.data.order - b.data.order)
  .filter((service) => !excludeIds.includes(service.id));

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<section id="services-teaser" class="site-section">
  <div class="site-shell">
    <div class="mb-10 grid gap-4">
      <span class="site-kicker site-reveal" data-reveal>Supporting services</span>
      <h2 class="site-section-title site-reveal site-reveal-stagger-1 max-w-3xl" data-reveal>{title}</h2>
      <p class="site-section-copy site-reveal site-reveal-stagger-2" data-reveal>{description}</p>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {sortedServices.map((service, index) => (
        <div
          class:list={[
            "site-reveal",
            index % 3 === 0 && "site-reveal-stagger-1",
            index % 3 === 1 && "site-reveal-stagger-2",
            index % 3 === 2 && "site-reveal-stagger-3",
          ]}
          data-reveal
        >
          <ServicePreviewCard
            service={service}
            href={`${base}services/${service.id}`}
          />
        </div>
      ))}
    </div>

    <div class="mt-8 site-reveal site-reveal-stagger-1" data-reveal>
      <a href={`${base}services`} class="site-button-secondary site-hover-lift">
        Explore all services
        <Icon name="mdi:arrow-right" class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>
