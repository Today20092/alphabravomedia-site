---
import { Icon } from "astro-icon/components";
import { siteConfig } from "../site-config";

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const questions = [
  {
    label: "Project type",
    prompt: "What are you looking for?",
    description: "Pick the closest match. This helps separate recurring work from one-off asks.",
    options: [
      {
        label: "Ongoing content or retainer",
        help: "Best fit for a recurring production relationship.",
        score: 3,
        redFlag: false,
      },
      {
        label: "Brand film or campaign piece",
        help: "A strong fit when the brief is clear and scoped.",
        score: 2,
        redFlag: false,
      },
      {
        label: "Event, podcast, or multi-cam production",
        help: "A good fit when timing and logistics are defined.",
        score: 2,
        redFlag: false,
      },
      {
        label: "Just a small one-off edit",
        help: "Usually too light for this offer.",
        score: 0,
        redFlag: true,
      },
    ],
  },
  {
    label: "Timeline",
    prompt: "How soon do you need it?",
    description: "Urgency matters. This helps show whether the scope has enough runway.",
    options: [
      {
        label: "Planning ahead",
        help: "Most comfortable for a polished production plan.",
        score: 3,
        redFlag: false,
      },
      {
        label: "Next month",
        help: "Still workable for a focused project.",
        score: 2,
        redFlag: false,
      },
      {
        label: "A little soon, but flexible",
        help: "Possible if the scope is tight.",
        score: 1,
        redFlag: false,
      },
      {
        label: "Need it immediately",
        help: "Usually not the right match.",
        score: 0,
        redFlag: true,
      },
    ],
  },
  {
    label: "Budget comfort",
    prompt: "Which range feels closest?",
    description: "The quiz is meant to save time by spotting budget mismatch early.",
    options: [
      {
        label: "Ready to invest in full production",
        help: "Aligned with a higher-touch offer.",
        score: 3,
        redFlag: false,
      },
      {
        label: "Comfortable with a mid-size project budget",
        help: "A good middle-ground fit.",
        score: 2,
        redFlag: false,
      },
      {
        label: "Budget not locked yet",
        help: "Still fine if the scope is flexible.",
        score: 1,
        redFlag: false,
      },
      {
        label: "Need the smallest spend possible",
        help: "Usually better handled by a leaner provider.",
        score: 0,
        redFlag: true,
      },
    ],
  },
  {
    label: "Support",
    prompt: "What kind of help do you need?",
    description: "This separates strategy-led work from simple task execution.",
    options: [
      {
        label: "Strategy, shooting, and editing",
        help: "This is the sweet spot.",
        score: 3,
        redFlag: false,
      },
      {
        label: "Production and editing",
        help: "Still a strong fit when the scope is clear.",
        score: 2,
        redFlag: false,
      },
      {
        label: "Editing only",
        help: "Possible, but not the strongest fit.",
        score: 1,
        redFlag: false,
      },
      {
        label: "Just a quick fix",
        help: "Usually too narrow for this offer.",
        score: 0,
        redFlag: true,
      },
    ],
  },
  {
    label: "Direction",
    prompt: "How clear is the vision?",
    description: "Clear references help a project move faster, but rough ideas can still work.",
    options: [
      {
        label: "I have references and a clear direction",
        help: "Ideal for a smooth start.",
        score: 2,
        redFlag: false,
      },
      {
        label: "I know the goal, need help shaping it",
        help: "A good middle point for strategy-led work.",
        score: 2,
        redFlag: false,
      },
      {
        label: "I need support from scratch",
        help: "Still possible if the scope and timing are right.",
        score: 1,
        redFlag: false,
      },
      {
        label: "I just need the fastest option",
        help: "Usually not the right match for this level of work.",
        score: 0,
        redFlag: true,
      },
    ],
  },
] as const;

const resultViews = {
  neutral: {
    badge: "Fit pending",
    title: "Answer a few questions to see your fit.",
    copy: "This is a soft check. It is meant to save time and point people to the right next step, not trap them in a form wall.",
    hint: "No email required. No pressure.",
  },
  good: {
    badge: "Good fit",
    title: "You look like a strong match.",
    copy: "The scope, timing, and budget all point toward a project or retainer worth a real conversation.",
    hint: "Best next step: reach out directly.",
  },
  maybe: {
    badge: "Maybe fit",
    title: "This could work with a quick call.",
    copy: "There is enough signal here to continue, but the scope would benefit from a short consult before either side commits.",
    hint: "Best next step: talk through scope and timing.",
  },
  "not-right": {
    badge: "Not right now",
    title: "Probably not the best fit today.",
    copy: "The answers suggest a mismatch in budget, timeline, or scope. A leaner provider or a different timing window may be a better path.",
    hint: "Best next step: revisit later or compare lighter options.",
  },
} as const;
---

<section id="fit-check" class="scroll-mt-32 px-4 pb-24 sm:px-6">
  <div class="site-shell">
    <div class="fit-check-shell overflow-hidden" data-fit-check>
      <div class="fit-check-grid">
        <div class="fit-check-intro">
          <div class="flex flex-wrap items-center gap-3">
            <span class="site-kicker">Fit Check</span>
            <span class="site-chip site-chip-muted">Prototype</span>
          </div>

          <div class="mt-4 max-w-3xl">
            <h2 class="site-section-title">
              See if Alpha Bravo Media is the right fit before you book the call.
            </h2>
            <p class="site-section-copy mt-4 text-base sm:text-lg">
              Five questions. No email wall. The result changes live so visitors can tell
              whether they should reach out, keep shaping the brief, or look for a lighter
              option.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-3 text-sm text-[var(--site-text-muted)]">
            <span class="site-stat">
              <span class="font-semibold text-[var(--site-accent)]">5</span>
              <span data-answer-count>0/5 answered</span>
            </span>
            <span class="site-stat">
              <Icon name="mdi:shield-check-outline" class="h-4 w-4 text-[var(--site-accent)]" />
              Soft qualifier
            </span>
            <span class="site-stat">
              <Icon name="mdi:timer-sand" class="h-4 w-4 text-[var(--site-accent)]" />
              Fast read, no form fields
            </span>
          </div>
        </div>

        <div class="fit-check-stage">
          <div class="fit-step-progress">
            <div class="flex flex-wrap items-end justify-between gap-3">
              <div>
                <span class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--site-text-soft)]">
                  Question progress
                </span>
                <p class="mt-2 text-sm text-[var(--site-text-muted)]" data-step-status>0/5 answered</p>
              </div>
              <span
                class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--site-text-soft)]"
                data-step-progress-label
              >
                01 / 05
              </span>
            </div>
            <div class="mt-4 h-1.5 rounded-full bg-[var(--site-control-bg-hover)]">
              <div
                class="quiz-meter-fill h-full w-0 rounded-full"
                data-step-progress
                style="width: 0%"
              ></div>
            </div>
          </div>

          <div class="mt-6">
            <section class="fit-step-card" data-step-shell data-step-state="question">
              <div class="flex flex-wrap items-center justify-between gap-4">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="site-chip site-chip-muted" data-step-label>{questions[0].label}</span>
                  <span
                    class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--site-text-soft)]"
                    data-step-position
                  >
                    01 / 05
                  </span>
                </div>
                <span class="site-stat fit-step-total">
                  <span class="font-semibold text-[var(--site-accent)]">5</span>
                  <span>questions total</span>
                </span>
              </div>

              <div class="mt-5 max-w-3xl">
                <h3
                  id="fit-question-active"
                  class="font-['Sora',sans-serif] text-xl font-semibold tracking-tight text-[var(--site-text)] sm:text-2xl"
                  data-step-prompt
                >
                  {questions[0].prompt}
                </h3>
                <p class="mt-2 max-w-2xl text-sm leading-7 text-[var(--site-text-muted)]" data-step-description>
                  {questions[0].description}
                </p>
              </div>

              <div class="fit-step-options mt-6 grid gap-3" data-step-options>
                {
                  questions[0].options.map((option, optionIndex) => (
                    <button
                      type="button"
                      class="quiz-option"
                      data-option
                      data-option-index={optionIndex}
                      aria-pressed="false"
                    >
                      <span class="quiz-option-copy">
                        <span class="quiz-option-label">{option.label}</span>
                        <span class="quiz-option-meta">{option.help}</span>
                      </span>
                      <span class="quiz-option-affordance" aria-hidden="true"></span>
                    </button>
                  ))
                }
              </div>

              <div class="fit-step-footer mt-6 flex flex-wrap items-center justify-between gap-3 text-xs text-[var(--site-text-soft)]">
                <button type="button" class="fit-step-back" data-step-back disabled>
                  Back
                </button>
                <span class="flex items-center gap-2" data-step-hint></span>
              </div>
            </section>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ questions, resultViews, contactHref: `${base}contact` }}>
  document.addEventListener("astro:page-load", () => {
    const root = document.querySelector("[data-fit-check]");

    if (!root || root.dataset.enhanced === "true") return;
    root.dataset.enhanced = "true";

    const stepShell = root.querySelector("[data-step-shell]");
    const stepLabel = root.querySelector("[data-step-label]");
    const stepPosition = root.querySelector("[data-step-position]");
    const stepStatus = root.querySelector("[data-step-status]");
    const stepPrompt = root.querySelector("[data-step-prompt]");
    const stepDescription = root.querySelector("[data-step-description]");
    const stepOptions = root.querySelector("[data-step-options]");
    const stepBack = root.querySelector("[data-step-back]");
    const stepHint = root.querySelector("[data-step-hint]");
    const stepProgress = root.querySelector("[data-step-progress]");
    const stepProgressLabel = root.querySelector("[data-step-progress-label]");
    const answerCount = root.querySelector("[data-answer-count]");
    const answerState = Array.from({ length: questions.length }, () => null);
    let currentIndex = 0;

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#39;");
    }

    function computeReadout() {
      let total = 0;
      let redFlags = 0;
      let answered = 0;
      const selections = [];

      answerState.forEach((entry, index) => {
        if (!entry) return;

        answered += 1;
        total += Number(entry.score || 0);
        if (entry.redFlag) redFlags += 1;

        selections.push({
          question: questions[index].label,
          answer: entry.label,
        });
      });

      let state = "neutral";

      if (answered > 0) {
        if (redFlags >= 2 || total <= 4) {
          state = "not-right";
        } else if (total >= 10 && redFlags === 0) {
          state = "good";
        } else {
          state = "maybe";
        }
      }

      return { state, total, answered, selections };
    }

    function renderStep(readout) {
      if (!stepShell) return;

      const completed = currentIndex >= questions.length;
      const answeredCount = readout.answered;
      const progress = Math.round((answeredCount / questions.length) * 100);
      const stepNumber = completed ? questions.length : currentIndex + 1;
      const stepNumberLabel = `${String(stepNumber).padStart(2, "0")} / ${String(questions.length).padStart(2, "0")}`;

      if (stepShell) stepShell.dataset.stepState = completed ? "complete" : "question";
      if (stepProgress) stepProgress.style.width = `${progress || 0}%`;
      if (stepProgressLabel) stepProgressLabel.textContent = stepNumberLabel;
      if (stepStatus) stepStatus.textContent = `${answeredCount}/${questions.length} answered`;

      if (completed) {
        const resultView = resultViews[readout.state];
        const meterWidth = Math.max(0, Math.min(100, Math.round((readout.total / 14) * 100)));
        if (stepLabel) stepLabel.textContent = "Complete";
        if (stepPosition) stepPosition.textContent = stepNumberLabel;
        if (stepPrompt) stepPrompt.textContent = "You finished the fit check.";
        if (stepDescription) {
          stepDescription.textContent =
            "See the readout, book the consult if it fits, or review your answers in place.";
        }
        if (stepHint) {
          stepHint.textContent = "Review answers or go back without leaving this section.";
        }
        if (stepBack) {
          stepBack.disabled = false;
          stepBack.textContent = "Back";
        }
        if (stepOptions) {
          const summaryItems = readout.selections.length
            ? readout.selections
                .map(
                  (entry) => `
                    <li class="flex items-start gap-3">
                      <span class="mt-2 inline-flex h-2.5 w-2.5 shrink-0 rounded-full bg-[var(--site-accent)]"></span>
                      <span><strong class="text-[var(--site-text)]">${escapeHtml(entry.question)}:</strong> ${escapeHtml(entry.answer)}</span>
                    </li>
                  `,
                )
                .join("")
            : "<li>No answers yet.</li>";

          stepOptions.innerHTML = `
            <div class="fit-complete-hero">
              <div class="fit-complete-copy">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="site-kicker">Readout</span>
                  <span class="site-chip site-chip-muted">${escapeHtml(resultView.badge)}</span>
                </div>
                <h4 class="fit-result-title mt-4 font-['Sora',sans-serif] text-2xl font-semibold tracking-tight text-[var(--site-text)] sm:text-[2.2rem]">
                  ${escapeHtml(resultView.title)}
                </h4>
                <p class="mt-3 max-w-3xl text-sm leading-7 text-[var(--site-text-muted)]">
                  ${escapeHtml(resultView.copy)}
                </p>
                <p class="mt-4 text-sm leading-6 text-[var(--site-text-soft)]">
                  ${escapeHtml(resultView.hint)}
                </p>
                <div class="fit-complete-meter">
                  <div class="flex items-end justify-between gap-4 text-sm text-[var(--site-text-soft)]">
                    <span>Fit meter</span>
                    <span>${readout.total} / 14</span>
                  </div>
                  <div class="mt-3 h-1.5 rounded-full bg-[var(--site-control-bg-hover)]">
                    <div class="quiz-meter-fill h-full rounded-full" style="width: ${meterWidth}%"></div>
                  </div>
                  <p class="mt-4 text-xs font-medium uppercase tracking-[0.18em] text-[var(--site-text-soft)]">
                    Scope, timing, budget, and support drive this read.
                  </p>
                </div>
              </div>
              <div class="fit-complete-actions mt-8" style="display:grid;gap:1.25rem;align-content:start;">
                <a href="${contactHref}" class="site-button-primary w-full">Book consult</a>
                <button
                  type="button"
                  class="site-button-secondary w-full fit-complete-review-button"
                  data-step-review
                >
                  Review answers
                </button>
              </div>
            </div>
            <div class="fit-complete-summary">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-[var(--site-text-soft)]">
                Your summary
              </p>
              <ul class="mt-4 grid gap-3 text-sm leading-6 text-[var(--site-text-muted)]">
                ${summaryItems}
              </ul>
            </div>
          `;
        }
        return;
      }

      const question = questions[currentIndex];
      const selected = answerState[currentIndex];
      const selectedHint = selected ? "Tap a different card to update your answer." : "";

      if (stepLabel) stepLabel.textContent = question.label;
      if (stepPosition) stepPosition.textContent = stepNumberLabel;
      if (stepPrompt) stepPrompt.textContent = question.prompt;
      if (stepDescription) stepDescription.textContent = question.description;
      if (stepHint) stepHint.textContent = selectedHint;
      if (stepBack) {
        stepBack.disabled = currentIndex === 0;
        stepBack.textContent = "Back";
      }
      if (stepOptions) {
        stepOptions.innerHTML = question.options
          .map((option, optionIndex) => {
            const isSelected = selected === option;

            return `
              <button
                type="button"
                class="quiz-option${isSelected ? " is-selected" : ""}"
                data-option
                data-option-index="${optionIndex}"
                aria-pressed="${isSelected ? "true" : "false"}"
              >
                <span class="quiz-option-copy">
                  <span class="quiz-option-label">${escapeHtml(option.label)}</span>
                  <span class="quiz-option-meta">${escapeHtml(option.help)}</span>
                </span>
                <span class="quiz-option-affordance${isSelected ? " is-selected" : ""}" aria-hidden="true"></span>
              </button>
            `;
          })
          .join("");
      }
    }

    function renderReadout(readout) {
      const { state, answered } = readout;

      root.dataset.fitState = state;

      if (answerCount) answerCount.textContent = `${answered}/${questions.length} answered`;
    }

    function syncState() {
      const readout = computeReadout();
      renderStep(readout);
      renderReadout(readout);
    }

    root.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof Element)) return;

      const optionButton = target.closest("[data-option]");
      if (optionButton instanceof HTMLButtonElement) {
        const optionIndex = Number(optionButton.getAttribute("data-option-index"));
        const question = questions[currentIndex];
        const selectedOption = question.options[optionIndex];

        if (!selectedOption) return;

        answerState[currentIndex] = selectedOption;
        currentIndex = Math.min(currentIndex + 1, questions.length);
        syncState();
        return;
      }

      const backButton = target.closest("[data-step-back]");
      if (backButton instanceof HTMLButtonElement) {
        currentIndex = currentIndex >= questions.length ? questions.length - 1 : Math.max(0, currentIndex - 1);
        syncState();
        return;
      }

      const reviewButton = target.closest("[data-step-review]");
      if (reviewButton instanceof HTMLButtonElement) {
        currentIndex = Math.max(questions.length - 1, 0);
        syncState();
      }
    });

    syncState();
  });
</script>

<style>
  .fit-check-shell {
    max-width: 76rem;
    margin-inline: auto;
    border: 1px solid var(--site-border);
    border-radius: 1.5rem;
    background:
      radial-gradient(circle at top left, color-mix(in oklab, var(--site-accent) 12%, transparent), transparent 34%),
      linear-gradient(180deg, color-mix(in oklab, var(--site-control-bg) 62%, transparent), transparent 45%),
      var(--site-surface);
    box-shadow: var(--site-shadow-md);
  }

  .fit-check-grid {
    display: grid;
    gap: 2rem;
    padding: 1.5rem;
  }

  .fit-check-intro {
    align-self: start;
  }

  .fit-check-stage {
    align-self: start;
  }

  .fit-step-progress {
    border-bottom: 1px solid color-mix(in oklab, var(--site-border) 86%, transparent);
    padding-bottom: 1.25rem;
  }

  .fit-check-shell[data-fit-state="good"] .fit-result-title {
    color: var(--site-accent-strong);
  }

  .fit-check-shell[data-fit-state="good"] .quiz-meter-fill {
    background: var(--site-accent-strong);
  }

  .fit-check-shell[data-fit-state="maybe"] .fit-result-title {
    color: oklch(0.82 0.11 74);
  }

  .fit-check-shell[data-fit-state="maybe"] .quiz-meter-fill {
    background: oklch(0.82 0.11 74);
  }

  .fit-check-shell[data-fit-state="not-right"] .fit-result-title {
    color: oklch(0.7 0.15 28);
  }

  .fit-check-shell[data-fit-state="not-right"] .quiz-meter-fill {
    background: oklch(0.7 0.15 28);
  }

  .quiz-meter-fill {
    background: var(--site-accent);
  }

  .fit-step-card {
    border: 1px solid var(--site-border);
    border-radius: 1.25rem;
    background: linear-gradient(180deg, var(--site-card-media-tint), transparent), var(--site-surface);
    padding: 1.25rem;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .fit-step-total {
    white-space: nowrap;
  }

  .fit-step-footer {
    border-top: 1px solid color-mix(in oklab, var(--site-border) 86%, transparent);
    padding-top: 1rem;
  }

  .fit-step-options {
    align-items: stretch;
  }

  .quiz-option {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    width: 100%;
    border: 1px solid var(--site-border);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--site-control-bg) 90%, var(--site-surface));
    padding: 1rem 1.05rem;
    text-align: left;
    cursor: pointer;
    transition:
      border-color 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .quiz-option:hover {
    border-color: var(--site-border-strong);
    background: var(--site-control-bg-hover);
    transform: translateY(-1px);
    box-shadow: var(--site-shadow-sm);
  }

  .quiz-option.is-selected {
    border-color: color-mix(in oklab, var(--site-accent) 35%, var(--site-border));
    background: var(--site-accent-soft);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--site-accent) 24%, transparent) inset;
  }

  .quiz-option-copy {
    display: grid;
    gap: 0.35rem;
    min-width: 0;
    flex: 1 1 auto;
  }

  .quiz-option-label {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.35;
    color: var(--site-text);
  }

  .quiz-option-meta {
    display: block;
    margin-top: 0.35rem;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--site-text-muted);
  }

  .quiz-option-affordance {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid color-mix(in oklab, var(--site-border) 88%, var(--site-accent));
    border-radius: 999px;
    color: var(--site-text-soft);
    background: color-mix(in oklab, var(--site-surface) 78%, transparent);
    flex: 0 0 auto;
  }

  .quiz-option-affordance::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border-top: 1.5px solid currentColor;
    border-right: 1.5px solid currentColor;
    transform: rotate(45deg);
    margin-left: -0.1rem;
  }

  .quiz-option.is-selected .quiz-option-affordance,
  .quiz-option-affordance.is-selected {
    color: var(--site-accent-strong);
    border-color: color-mix(in oklab, var(--site-accent) 35%, var(--site-border));
    background: color-mix(in oklab, var(--site-accent-soft) 70%, var(--site-surface));
  }

  .fit-step-back {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--site-text-soft);
    transition: color 180ms ease, opacity 180ms ease;
  }

  .fit-step-back:hover:not(:disabled) {
    color: var(--site-text);
  }

  .fit-step-back:disabled {
    opacity: 0.38;
    cursor: not-allowed;
