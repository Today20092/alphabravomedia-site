---
import PricingCard from "./PricingCard.astro";
import { Icon } from "astro-icon/components";

export interface Props {
  service: any;
}

const { service } = Astro.props;
---

<div class="grid gap-8" id={`service-${service.id}`}>
  <div class="mx-auto grid max-w-3xl gap-4 text-center">
    <h2 class="site-section-title">{service.data.title}</h2>
    <p class="site-section-copy mx-auto">{service.data.description}</p>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    {
      service.data.tiers.map((tierWrapper: any) => {
        const tier = tierWrapper.value;

        return (
          <PricingCard
            name={tier.name}
            price={tier.price}
            bestFor={tier.bestFor}
            isPopular={tier.isPopular}
            includes={tier.includes}
          />
        );
      })
    }
  </div>

  {
    service.data.portfolioLink && (
      <div>
        <a href={service.data.portfolioLink} class="site-button-secondary">
          View related portfolio work
          <Icon name="mdi:arrow-right" class="h-4 w-4" />
        </a>
      </div>
    )
  }
</div>
