---
import { getCollection } from "astro:content";
import ServicePricingBlock from "./ServicePricingBlock.astro";

const allServices = await getCollection("services");
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);
---

<section id="services" class="border-t border-[var(--site-border)] px-6 py-24">
  <div class="site-shell">
    <div class="mb-10 grid gap-4 text-center">
      <span class="site-kicker mx-auto">Services</span>
      <h2 class="site-section-title">Packages and retainers</h2>
      <p class="site-section-copy mx-auto">
        Transparent pricing, consistent production standards, and a quieter comparison
        view that keeps the package differences readable.
      </p>
    </div>

    <div
      class="mb-10 flex flex-col items-stretch gap-3 sm:flex-row sm:flex-wrap sm:justify-center"
      id="services-tabs"
      role="tablist"
    >
      {
        sortedServices.map((service, index) => (
          <button
            role="tab"
            aria-selected={index === 0 ? "true" : "false"}
            aria-controls={`panel-${service.id}`}
            id={`tab-${service.id}`}
            class={`service-tab site-button-secondary ${index === 0 ? "is-active" : ""}`}
            data-target={`panel-${service.id}`}
          >
            {service.data.title}
          </button>
        ))
      }
    </div>

    <div id="services-panels">
      {
        sortedServices.map((service, index) => (
          <div
            id={`panel-${service.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${service.id}`}
            class={index === 0 ? "block" : "hidden"}
          >
            <ServicePricingBlock service={service} />
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.addEventListener("astro:page-load", () => {
    const tabButtons = document.querySelectorAll("#services-tabs button");
    const tabPanels = document.querySelectorAll(
      '#services-panels [role="tabpanel"]',
    );

    if (tabButtons.length === 0) return;

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        tabButtons.forEach((btn) => {
          btn.setAttribute("aria-selected", "false");
          btn.classList.remove("is-active");
        });

        tabPanels.forEach((panel) => {
          panel.classList.add("hidden");
        });

        button.setAttribute("aria-selected", "true");
        button.classList.add("is-active");

        const targetId = button.getAttribute("data-target");
        if (!targetId) return;

        const targetPanel = document.getElementById(targetId);
        if (targetPanel) {
          targetPanel.classList.remove("hidden");
        }
      });
    });
  });
</script>

<style>
  .service-tab.is-active {
    border-color: color-mix(in oklab, var(--site-accent) 28%, transparent);
    background: var(--site-accent-soft);
    color: var(--site-accent);
  }
</style>
