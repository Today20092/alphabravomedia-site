---
// SearchModal.astro — no props needed
import { Icon } from "astro-icon/components";
---

<!-- Backdrop -->
<div
  id="search-backdrop"
  class="fixed inset-0 z-90 bg-black/60 backdrop-blur-sm"
  style="display:none"
  aria-hidden="true"
>
</div>

<!-- Modal Dialog -->
<dialog
  id="search-modal"
  class="fixed inset-0 z-100 m-auto w-full max-w-2xl max-h-[80vh]
         bg-[#111111]/90 backdrop-blur-xl border border-[#2a2520]
         rounded-2xl shadow-2xl shadow-black/60 p-6 overflow-hidden
         flex-col"
  aria-label="Site search"
>
  <!-- Modal Header -->
  <div class="flex items-center justify-between mb-4 shrink-0">
    <div class="flex items-center gap-3">
      <Icon name="mdi:magnify" class="w-5 h-5 text-[#a8998a]" />
      <span class="text-sm font-medium text-[#a8998a]">Search</span>
    </div>
    <div class="flex items-center gap-3">
      <span class="hidden sm:flex items-center gap-1 text-xs text-[#7a6f63]">
        <kbd
          class="px-1.5 py-0.5 bg-white/5 border border-[#2a2520] rounded text-[#7a6f63] font-mono text-xs"
          >Esc</kbd
        >
        to close
      </span>
      <button
        id="search-close"
        class="p-1.5 text-[#a8998a] hover:text-white hover:bg-white/10 rounded-lg transition-colors"
        aria-label="Close search"
      >
        <Icon name="mdi:close" class="w-5 h-5" />
      </button>
    </div>
  </div>

  <!-- Pagefind UI Mount Point -->
  <div id="pagefind-search" class="overflow-y-auto flex-1 min-h-0"></div>
</dialog>

<style>
  dialog::backdrop {
    display: none;
  }

  dialog {
    opacity: 0;
    transform: translateY(-8px) scale(0.98);
    transition:
      opacity 200ms ease,
      transform 200ms ease;
    display: none;
  }

  dialog[open] {
    display: flex;
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  dialog.closing {
    opacity: 0;
    transform: translateY(-8px) scale(0.98);
  }
</style>

<script>
  let pagefindLoaded = false;

  async function loadPagefind() {
    if (pagefindLoaded) return;
    pagefindLoaded = true;

    const base = import.meta.env.BASE_URL.endsWith("/")
      ? import.meta.env.BASE_URL
      : import.meta.env.BASE_URL + "/";

    try {
      const url = `${base}pagefind/pagefind-ui.js`;
      await new Promise<void>((resolve, reject) => {
        const script = document.createElement("script");
        script.src = url;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error(`Failed to load ${url}`));
        document.head.appendChild(script);
      });
      new (window as any).PagefindUI({
        element: "#pagefind-search",
        showSubResults: false,
        showImages: false,
        excerptLength: 20,
        translations: {
          placeholder: "Search posts, portfolio, gear\u2026",
          zero_results: "No results for [SEARCH_TERM]",
        },
      });

      requestAnimationFrame(() => {
        const input = document.querySelector(
          ".pagefind-ui__search-input",
        ) as HTMLInputElement | null;
        if (input) input.focus();
      });
    } catch (e) {
      console.error("Pagefind failed to load:", e);
    }
  }

  function setupSearch() {
    const modal = document.getElementById(
      "search-modal",
    ) as HTMLDialogElement | null;
    const backdrop = document.getElementById(
      "search-backdrop",
    ) as HTMLElement | null;
    const openBtns = document.querySelectorAll("[data-search-open]");
    const closeBtn = document.getElementById("search-close");

    if (!modal) return;

    function openModal(e?: Event) {
      if (e) e.preventDefault();
      modal?.showModal();
      if (backdrop) backdrop.style.display = "block";
      document.body.style.overflow = "hidden";

      // Also close the mobile menu if it is open
      const mobileMenu = document.getElementById("mobile-menu");
      const menuOpen = document.getElementById("menu-open");
      const menuClose = document.getElementById("menu-close");
      if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
        mobileMenu.classList.add("hidden");
        menuOpen?.classList.remove("hidden");
        menuClose?.classList.add("hidden");
      }

      loadPagefind();
    }

    function closeModal() {
      modal?.classList.add("closing");
      if (backdrop) backdrop.style.display = "none";
      setTimeout(() => {
        modal?.close();
        modal?.classList.remove("closing");
        document.body.style.overflow = "";
      }, 150);
    }

    openBtns.forEach((btn) => btn.addEventListener("click", openModal));
    closeBtn?.addEventListener("click", closeModal);
    backdrop?.addEventListener("click", closeModal);

    modal.addEventListener("close", () => {
      document.body.style.overflow = "";
      if (backdrop) backdrop.style.display = "none";
    });

    // Cleanup old keydown listener if any to avoid duplicates across page loads
    if ((window as any)._searchKeydownHandler) {
      window.removeEventListener(
        "keydown",
        (window as any)._searchKeydownHandler,
      );
    }

    (window as any)._searchKeydownHandler = (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "k") {
        e.preventDefault();
        if (modal?.open) {
          closeModal();
        } else {
          openModal();
        }
      }
    };

    window.addEventListener("keydown", (window as any)._searchKeydownHandler);
  }

  document.addEventListener("astro:page-load", setupSearch);
</script>
